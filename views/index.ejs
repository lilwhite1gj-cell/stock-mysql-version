        function updateDynamicHints(prefix) {
            const cat = getEl(prefix + 'Cat').value || '';
            const isSample = cat.includes('样品');
            
            // 定义在“样品”模式下变为选填的字段后缀
            const optionalSuffixes = ['Sku', 'Cust', 'Fact', 'Price', 'Curr', 'Pack', 'Notes', 'CustAddr', 'CustPhone'];
            
            optionalSuffixes.forEach(s => {
                const el = getEl(prefix + s);
                if(!el) return;
                
                // 获取不含“(选填)”的基础提示文字
                const baseHint = (el.getAttribute('placeholder') || (el.options && el.options[0] ? el.options[0].text : '')).replace(' (选填)', '');
                
                if(isSample) {
                    // 设置为选填样式
                    if(el.tagName === 'SELECT') {
                        if(el.options[0]) el.options[0].text = baseHint + ' (选填)';
                    } else {
                        el.setAttribute('placeholder', baseHint + ' (选填)');
                    }
                    el.classList.add('bg-slate-50', 'text-slate-400');
                    el.classList.remove('bg-white', 'bg-slate-100');
                } else {
                    // 恢复为必填样式
                    if(el.tagName === 'SELECT') {
                        if(el.options[0]) el.options[0].text = baseHint;
                    } else {
                        el.setAttribute('placeholder', baseHint);
                    }
                    el.classList.remove('bg-slate-50', 'text-slate-400');
                    el.classList.add(prefix === 'p' ? 'bg-slate-100' : 'bg-white');
                }
            });
        }

