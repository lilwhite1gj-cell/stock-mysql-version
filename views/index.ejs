<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>库存专家 Pro - OEM 库存管理系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/lucide.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
        body { background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 50%, #f0f9ff 100%); font-family: 'Inter', -apple-system, sans-serif; -webkit-tap-highlight-color: transparent; }
        .nav-item { display: flex; align-items: center; padding: 0.8rem 1.25rem; color: #94a3b8; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; border-radius: 14px; margin: 2px 12px; position: relative; }
        .nav-item::before { content: ''; position: absolute; left: -12px; top: 50%; transform: translateY(-50%); width: 4px; height: 0; background: transparent; border-radius: 0 4px 4px 0; transition: all 0.3s ease; }
        .nav-item:hover { color: #e2e8f0; background: rgba(99,102,241,0.08); }
        .nav-item:active { transform: scale(0.97); }
        .nav-item.active { background: linear-gradient(135deg, #6366f1, #818cf8); color: white; box-shadow: 0 8px 24px -4px rgba(99,102,241,0.45); margin-left: 0; margin-right: 0; border-radius: 0 14px 14px 0; }
        .nav-item.active::before { background: white; height: 60%; top: 20%; transform: none; }
        .glass-card { background: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.6); box-shadow: 0 4px 24px -4px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04); border-radius: 24px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); backdrop-filter: blur(12px); }
        .glass-card:hover { box-shadow: 0 12px 40px -8px rgba(99,102,241,0.12), 0 4px 12px rgba(0,0,0,0.04); transform: translateY(-2px); }
        .clickable-row { cursor: pointer; }
        .clickable-row:active { transform: scale(0.98); background-color: #f1f5f9 !important; }
        .page-enter { animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @keyframes pageIn { from { opacity: 0; transform: translateY(24px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
        .stat-card { position: relative; overflow: hidden; }
        .stat-card::after { content: ''; position: absolute; top: -50%; right: -30%; width: 120px; height: 120px; border-radius: 50%; opacity: 0.08; }
        @media (max-width: 768px) {
            .rate-display { font-size: 10px; padding: 4px 10px; border-radius: 8px; }
            .currency-toggle-btn { padding: 10px 16px; font-size: 12px; border-radius: 16px; }
            .modal-drawer { 
                position: fixed; bottom: 0; left: 0; right: 0; width: 100%; 
                border-radius: 48px 48px 0 0 !important; 
                max-height: 94vh !important; 
                padding-top: 12px;
                animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1); 
                display: flex; flex-direction: column;
                box-shadow: 0 -25px 60px -12px rgba(0,0,0,0.25);
                z-index: 300;
            }
            .modal-handle { width: 40px; height: 5px; background: #e2e8f0; border-radius: 10px; margin: 0 auto 15px; flex-shrink: 0; }
            @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
            .modal-scroll { padding-bottom: 80px; padding-left: 20px; padding-right: 20px; }
            .glass-card { border-radius: 32px; padding: 1.25rem !important; }
            .p-10 { padding: 1.5rem !important; }
        }
        .modal-scroll { overflow-y: auto !important; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
        .detail-scroll-fix { overflow-y: auto !important; -webkit-overflow-scrolling: touch; }
        .detail-scroll-fix::-webkit-scrollbar { display: block; width: 5px; }
        .detail-scroll-fix::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .detail-scroll-fix::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #c7d2fe, #a5b4fc); border-radius: 10px; }
        ::-webkit-scrollbar-track { background: transparent; }
        
        /* 图片悬停放大特效 - 增强版 */
        .hover-zoom-trigger { 
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease; 
            cursor: zoom-in; 
            position: relative; 
            z-index: 10;
            will-change: transform;
            transform-origin: left center; /* 从左向右展开，避开侧边栏 */
        }
        .hover-zoom-trigger:hover { 
            transform: scale(3.8) translateX(15px); 
            z-index: 999 !important; 
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
            border-radius: 12px;
        }
        /* 确保表格容器不拦截溢出内容 */
        .table-container-fix { overflow: visible !important; }
        
        /* 移除数字输入框的滚轮调节和箭头，防止滚动冲突 */
        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        input[type=number] { -moz-appearance: textfield; }
        .error-bubble { color: #e11d48; font-size: 10px; font-weight: 800; margin-top: 4px; animation: shake 0.4s ease; }
        @keyframes shake { 0%,100% {transform:translateX(0)} 25% {transform:translateX(-4px)} 75% {transform:translateX(4px)} }

        /* 移动端底部导航栏 */
        .bottom-nav { display: none; }
        .bottom-nav.visible { display: flex; }
        @media (max-width: 768px) {
            .bottom-nav.visible {
                display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
                background: rgba(255,255,255,0.95); backdrop-filter: blur(24px) saturate(200%); -webkit-backdrop-filter: blur(24px) saturate(200%);
                border-top: 1px solid rgba(226,232,240,0.4);
                padding: 6px 0 calc(6px + env(safe-area-inset-bottom, 0px));
                justify-content: space-around; align-items: center;
                box-shadow: 0 -4px 24px rgba(99,102,241,0.08), 0 -1px 6px rgba(0,0,0,0.04);
            }
            .bottom-nav-item {
                display: flex; flex-direction: column; align-items: center; justify-content: center;
                padding: 8px 0 4px; min-width: 56px; flex: 1; cursor: pointer;
                color: #94a3b8; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                -webkit-tap-highlight-color: transparent; position: relative;
                border-radius: 12px;
            }
            .bottom-nav-item i { width: 24px; height: 24px; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
            .bottom-nav-item span { font-size: 10px; font-weight: 600; margin-top: 3px; letter-spacing: 0.02em; transition: all 0.3s ease; }
            .bottom-nav-item.active { color: #6366f1; }
            .bottom-nav-item.active i { transform: scale(1.15) translateY(-1px); }
            .bottom-nav-item.active span { font-weight: 800; }
            .bottom-nav-item.active::before {
                content: ''; position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
                width: 24px; height: 3px; border-radius: 0 0 4px 4px;
                background: linear-gradient(90deg, #6366f1, #818cf8);
                box-shadow: 0 2px 8px rgba(99,102,241,0.4);
            }
            /* 活跃tab背景光晕 */
            .bottom-nav-item.active::after {
                content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
                width: 44px; height: 44px; border-radius: 50%;
                background: radial-gradient(circle, rgba(99,102,241,0.1) 0%, transparent 70%);
                pointer-events: none;
            }
            .bottom-nav-item:active { transform: scale(0.9); transition-duration: 0.1s; }

            /* 移动端主内容区底部留白(给底部导航栏) */
            #app-content { padding-bottom: 80px !important; }

            /* 移动端页面标题缩小 */
            .text-4xl { font-size: 1.375rem !important; line-height: 1.8rem !important; letter-spacing: -0.02em !important; }

            /* 移动端主内容区减少水平padding */
            #mainContainer { padding: 0.625rem !important; }

            /* 移动端仪表盘页面间距紧凑 */
            #page-dashboard { gap: 0.75rem !important; }
            #page-dashboard > .flex { margin-bottom: 0 !important; }

            /* 移动端页面间距优化 */
            .page-content { gap: 0.75rem !important; }

            /* 移动端统计卡片 - 紧凑美观 */
            #statCards { gap: 0.625rem !important; }
            #statCards .glass-card { padding: 0.75rem 0.875rem !important; border-radius: 18px !important; }
            #statCards .text-3xl { font-size: 1rem !important; line-height: 1.3 !important; }
            #statCards .text-\[10px\] { font-size: 8px !important; margin-bottom: 4px !important; }
            #statCards .bg-gradient-to-br { padding: 0.5rem !important; border-radius: 14px !important; }
            #statCards .bg-gradient-to-br i, #statCards .bg-gradient-to-br svg { width: 16px !important; height: 16px !important; }

            /* 移动端图表：环状图自适应正方形容器 */
            .chart-doughnut-wrap { position: relative; width: 100%; max-width: 280px; margin: 0 auto; aspect-ratio: 1 / 1; }
            .chart-doughnut-wrap canvas { width: 100% !important; height: 100% !important; }
            #productQtyChart, #productValueChart { height: auto !important; }
            #sampleQtyChart { height: 260px !important; }
            /* 图表卡片移动端紧凑 */
            .chart-card-mobile { padding: 1rem !important; border-radius: 20px !important; }
            .chart-card-mobile h3 { font-size: 0.875rem !important; margin-bottom: 0.75rem !important; }

            /* 移动端登录表单适配 */
            #page-login > div { padding: 1.25rem !important; border-radius: 28px !important; margin: 0 6px; }
            #page-login .py-5 { padding-top: 0.75rem !important; padding-bottom: 0.75rem !important; }
            #page-login .space-y-4 > * + * { margin-top: 0.5rem !important; }
            #page-login input, #page-login select { padding: 0.875rem 1rem !important; font-size: 16px !important; border-radius: 18px !important; }

            /* 移动端库存页头部操作栏 */
            .inv-header { flex-direction: column !important; align-items: stretch !important; gap: 0.75rem; }
            .inv-header-actions { flex-direction: row !important; flex-wrap: wrap; gap: 0.5rem; }
            .inv-header-actions .currency-toggle-btn { font-size: 10px; padding: 6px 10px; }

            /* 移动端收发明细页头部 */
            .trans-header { flex-direction: column !important; align-items: stretch !important; gap: 0.75rem; }
            .trans-header-actions { flex-direction: row !important; flex-wrap: wrap; gap: 0.5rem; }
            .trans-header-actions .currency-toggle-btn { font-size: 10px; padding: 6px 10px; }

            /* 移动端筛选栏优化 */
            .trans-filters { grid-template-columns: 1fr 1fr !important; gap: 0.5rem !important; }
            .trans-filters > div { padding: 0.6rem 0.75rem !important; border-radius: 14px !important; }
            .trans-filters .text-\[9px\] { font-size: 8px !important; }
            .trans-filters select, .trans-filters input { font-size: 11px !important; }

            /* 移动端弹窗表单适配 */
            .modal-drawer .grid.grid-cols-2 { grid-template-columns: 1fr !important; gap: 0.5rem !important; }
            .modal-drawer .grid.grid-cols-3 { grid-template-columns: 1fr 1fr !important; gap: 0.5rem !important; }
            .modal-drawer input, .modal-drawer select, .modal-drawer textarea {
                padding: 0.875rem 1rem !important; font-size: 16px !important; border-radius: 16px !important;
            }
            .modal-drawer .p-6, .modal-drawer .p-5 { padding: 0.75rem !important; }
            .modal-drawer .text-2xl { font-size: 1.125rem !important; }

            /* 移动端设置页 */
            #page-settings .glass-card { padding: 1.25rem !important; border-radius: 20px !important; }
            #page-settings .overflow-x-auto { -webkit-overflow-scrolling: touch; }

            /* 移动端详情弹窗 */
            #detailModal .p-6.md\:p-8 { padding: 1rem !important; }
            #detailModal .p-6.md\:p-12 { padding: 1rem !important; }
            #detailModal .text-6xl { font-size: 2.5rem !important; }
            #detailModal .text-3xl.md\:text-4xl { font-size: 1.5rem !important; }
            #detailModal .rounded-\[40px\], #detailModal .rounded-\[48px\] { border-radius: 20px !important; }

            /* 移动端预警面板 */
            #alertSection .p-8 { padding: 1rem !important; }

            /* 移动端工厂/客户卡片 */
            #factoryListContent .glass-card, #customerListContent .glass-card {
                padding: 1rem !important; border-radius: 20px !important;
            }
            #factoryListContent, #customerListContent {
                grid-template-columns: 1fr !important; gap: 0.75rem !important;
            }

            /* 移动端安全区域 */
            body { padding-bottom: env(safe-area-inset-bottom, 0px); }

            /* 移动端toast位置调整 */
            #toast { bottom: calc(80px + env(safe-area-inset-bottom, 0px)) !important; }
        }

        /* 小屏手机额外适配 (≤375px) */
        @media (max-width: 375px) {
            .bottom-nav-item span { font-size: 8px; }
            .bottom-nav-item i { width: 20px; height: 20px; }
            .bottom-nav-item { padding: 4px 0 1px; min-width: 48px; }
            .text-4xl { font-size: 1.125rem !important; }
            .trans-filters { grid-template-columns: 1fr !important; }
            #mainContainer { padding: 0.5rem !important; }
            #statCards .glass-card { padding: 0.625rem 0.75rem !important; }
            #statCards .text-3xl { font-size: 0.875rem !important; }
            .chart-doughnut-wrap { max-width: 240px; }
        }

        /* ============================================================
           以下为 UI 全面优化增强（可读性 / 响应式 / 动效 / 无障碍）
           仅调整视觉与体验，不改动任何交互逻辑与功能
           ============================================================ */

        /* ---------- 1. 可读性 & 对比度 ---------- */
        :root {
            --c-text: #1e293b;        /* slate-800 正文 */
            --c-text-soft: #475569;   /* slate-600 次级 */
            --c-text-muted: #64748b;  /* 提亮后的 slate-400/500 辅助文字 */
            --c-primary: #6366f1;
            --focus-ring: #6366f1;
        }
        /* 提升正文最小字号与行高（不影响 Tailwind 间距体系） */
        .text-base { font-size: 16px !important; line-height: 1.6 !important; }
        .text-sm   { font-size: 14.5px !important; line-height: 1.55 !important; }
        .text-xs   { font-size: 13px !important; line-height: 1.5 !important; }
        /* 浅色背景上 slate-400/500 原对比度不足，整体提亮 */
        .text-slate-400 { color: #64748b !important; }
        .text-slate-500 { color: #475569 !important; }
        .text-slate-300 { color: #94a3b8 !important; }
        /* 表单占位符即“字段标签”，提升字号与对比度 */
        input::placeholder, textarea::placeholder, select::placeholder {
            color: #64748b !important; opacity: 1; font-size: 15px;
        }
        /* 表单控件基础字号（桌面端 ≥15px，移动端保持 16px） */
        input, select, textarea {
            font-size: 15px;
            transition: box-shadow .2s ease, background-color .2s ease, border-color .2s ease;
        }
        /* 键盘聚焦可见反馈（可访问性） */
        input:focus-visible, select:focus-visible, textarea:focus-visible,
        button:focus-visible, a:focus-visible, [tabindex]:focus-visible {
            outline: 2px solid var(--focus-ring); outline-offset: 2px;
        }

        /* ---------- 2. 交互过渡 & 触感反馈 ---------- */
        button, .btn, [role="button"] {
            transition: transform .15s cubic-bezier(0.16, 1, 0.3, 1),
                        box-shadow .2s ease, background-color .2s ease,
                        color .2s ease, filter .2s ease;
        }
        button:active:not(:disabled) { transform: scale(0.97); }
        /* 表单提交 / 保存按钮加载态（配合 JS 添加 .btn-loading 即可显示转圈） */
        .btn-loading { position: relative; pointer-events: none; opacity: .85; }
        .btn-loading::after {
            content: ''; position: absolute; right: 18px; top: 50%; width: 18px; height: 18px;
            margin-top: -9px; border: 2px solid rgba(255,255,255,.45); border-top-color: #fff;
            border-radius: 50%; animation: btnSpin .7s linear infinite;
        }
        @keyframes btnSpin { to { transform: rotate(360deg); } }

        /* ---------- 3. 桌面端 / 平板端 布局 ---------- */
        @media (min-width: 1024px) {
            /* 让主滚动容器占满右侧区域，滚动条贴屏幕边缘；内容区内边距由 lg:p-10 保留 */
            #mainContainer { width: 100%; }
        }
        @media (min-width: 768px) and (max-width: 1023px) {
            #mainContainer { padding: 1.75rem; }
            #statCards { gap: 1rem; }
        }

        /* ---------- 4. 弹窗入场动画（桌面端；移动端沿用 slideUp） ---------- */
        @media (min-width: 769px) {
            .modal-drawer { animation: modalPop .26s cubic-bezier(0.16, 1, 0.3, 1); }
        }
        @keyframes modalPop {
            from { opacity: 0; transform: scale(.96) translateY(10px); }
            to   { opacity: 1; transform: none; }
        }
        /* 遮罩淡入 */
        .fixed.inset-0[class*="bg-slate-900/70"] { animation: overlayIn .2s ease; }
        @keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }

        /* ---------- 5. 更新日志可读性 ---------- */
        #changelogContent { font-size: 15px; line-height: 1.85; color: var(--c-text); }
        #changelogContent .font-black.text-slate-800 { font-size: 17px; color: #1e293b; }
        #changelogContent li { font-size: 14.5px; color: #475569; line-height: 1.7; }
        #changelogContent .text-\[10px\] { font-size: 12px !important; color: #64748b !important; }
        #changelogContent ul { list-style: none; padding-left: 0; }
        #changelogContent li::before {
            content: '•'; color: #c7d2fe; font-weight: 900; margin-right: 8px;
        }

        /* ---------- 6. 防止横向溢出 ---------- */
        html { overflow-x: hidden; }
        img, svg, canvas { max-width: 100%; }

        /* ---------- 7. 尊重“减少动效”偏好（无障碍） ---------- */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: .001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: .001ms !important;
                scroll-behavior: auto !important;
            }
        }
    </style>
</head>

<body class="flex h-screen overflow-hidden text-slate-800 select-none">
    <datalist id="customerDataList"></datalist>
    <div id="toast" class="hidden fixed bottom-10 left-1/2 -translate-x-1/2 z-[9999] px-6 py-4 rounded-3xl shadow-2xl transition-all duration-500 font-black text-sm flex items-center text-white min-w-[280px] justify-center text-center"></div>
    <!-- 全局加载遮罩 -->
    <div id="globalLoading" class="hidden fixed inset-0 z-[600] bg-slate-900/40 backdrop-blur-md flex flex-col items-center justify-center">
        <div class="w-20 h-20 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-white font-black text-lg tracking-widest animate-pulse">正在同步云端数据库...</p>
        <p class="text-white/60 text-xs mt-2">首次上传图片可能较慢，请勿关闭页面</p>
    </div>
    <div id="imgPreviewOverlay" onclick="this.classList.add('hidden')" class="hidden fixed inset-0 z-[400] bg-black/95 backdrop-blur-2xl flex items-center justify-center p-4">
        <img id="imgPreviewContent" src="" class="max-w-full max-h-full rounded-3xl shadow-2xl border border-white/10 animate-in zoom-in-95 duration-300">
    </div>

    <!-- 更新日志弹窗 -->
    <div id="changelogModal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-0 md:p-6 bg-slate-900/70 backdrop-blur-lg">
        <div class="bg-white/95 backdrop-blur-xl w-full max-w-lg rounded-none md:rounded-[48px] p-8 md:p-12 shadow-2xl overflow-hidden flex flex-col h-full md:max-h-[85vh] modal-drawer">
            <div class="md:hidden modal-handle"></div>
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-2xl font-black tracking-tighter text-slate-800">更新日志</h3>
                <button onclick="closeModal('changelogModal')" class="p-2 hover:bg-slate-100 rounded-xl transition-all"><i data-lucide="x" class="w-5 h-5 text-slate-400"></i></button>
            </div>
            <div id="changelogContent" class="flex-1 overflow-y-auto space-y-6 modal-scroll pr-2 pb-10 text-sm text-slate-600 leading-relaxed"></div>
        </div>
    </div>

    <aside id="sidebar" class="fixed inset-y-0 left-0 z-[100] w-72 bg-gradient-to-b from-slate-900 via-slate-900 to-slate-800 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-500 cubic-bezier(0.16, 1, 0.3, 1) flex flex-col shadow-2xl">
        <div class="p-8 border-b border-white/5 flex items-center space-x-4">
            <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-indigo-700 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/30"><i data-lucide="package" class="text-white w-6 h-6"></i></div>
            <div><h1 class="text-white font-black tracking-tighter text-xl text-center">库存专家</h1><p id="roleDisplay" class="text-[10px] text-slate-500 font-black uppercase tracking-widest text-center"></p></div>
        </div>
        <div class="mt-8 flex-1 space-y-1 overflow-y-auto px-2">
            <div onclick="showPage('dashboard')" id="nav-dashboard" class="nav-item active"><i data-lucide="layout-grid" class="w-5 h-5 mr-4"></i> 仪表盘看板</div>
            <div onclick="showPage('inventory')" id="nav-inventory" class="nav-item"><i data-lucide="box" class="w-5 h-5 mr-4"></i> 库存台账</div>
