        async function fetchUsers() {
            try {
                const res = await api.get('/admin/users');
                const list = res.data.map(u => {
                    const isS = currentUser.role === 'admin', self = u.id === currentUser.id;
                    const roleColor = u.role === 'admin' ? 'bg-indigo-100 text-indigo-600' : (u.role === 'manager' ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-100 text-slate-400');
                    let btns = `<button onclick="resetUserPassword('${u.id}','${esc(u.username)}')" class="bg-white border border-slate-200 px-4 py-2 rounded-xl text-slate-600 font-black text-xs shadow-sm hover:bg-slate-50">重置</button>`;
                    if(isS && !self && u.role !== 'admin') btns += `<button onclick="doDeleteUser('${u.id}','${esc(u.username)}')" class="ml-2 bg-rose-50 border border-rose-100 text-rose-500 px-4 py-2 rounded-xl font-black text-xs shadow-sm">删除</button>`;
                    if(isS && !self && u.role === 'staff') btns += `<button onclick="changeRole('${u.id}','manager')" class="ml-2 bg-emerald-50 border border-emerald-100 text-emerald-600 px-4 py-2 rounded-xl font-black text-xs">提升</button>`;
                    if(isS && !self && u.role === 'manager') btns += `<button onclick="changeRole('${u.id}','staff')" class="ml-2 bg-rose-50 border border-rose-100 text-rose-500 px-4 py-2 rounded-xl font-black text-xs">撤销</button>`;
                    return `<tr class="text-sm border-b border-slate-50 hover:bg-slate-50/50 transition-colors"><td class="p-6"><div class="flex items-center space-x-3"><div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-black text-slate-400 text-xs">${u.username.charAt(0).toUpperCase()}</div><div class="font-black text-slate-700">${esc(u.username)} ${self?'(本人)':''}</div></div></td><td class="p-6 uppercase font-bold text-slate-300 text-[10px] tracking-widest">${esc(u.role)}</td><td class="p-6 text-slate-400 font-mono text-xs">${esc(u.phone||'-')}</td><td class="p-6 text-right">${btns}</td></tr>`;
                }).join('');
                getEl('userListTable').innerHTML = list; lucide.createIcons();
            } catch(e) {}
        }
        
