    <div id="detailModal" onclick="if(event.target === this) closeModal('detailModal')" class="hidden fixed inset-0 z-[250] flex items-end md:items-center justify-center p-0 md:p-6 bg-slate-900/80 backdrop-blur-xl">
        <div class="bg-white/95 backdrop-blur-xl w-full max-w-3xl rounded-t-[48px] md:rounded-[56px] shadow-2xl overflow-hidden flex flex-col h-[90vh] md:h-[85vh] modal-drawer">
            <div class="p-6 md:p-8 border-b border-slate-50 flex justify-between items-center bg-slate-50/30 sticky top-0 z-20"><h3 id="detailTitle" class="text-xl md:text-2xl font-black text-slate-900 tracking-tighter"></h3><button onclick="closeModal('detailModal')" class="p-3 bg-white rounded-2xl shadow-sm hover:bg-slate-50 transition-colors"><i data-lucide="x"></i></button></div>
            <div id="detailContent" class="p-6 md:p-12 space-y-8 md:space-y-10 flex-1 detail-scroll-fix"></div>
            <div class="p-6 md:p-8 bg-slate-50/50 text-center border-t border-slate-100 sticky bottom-0 z-20"><button onclick="closeModal('detailModal')" class="w-full max-w-xs py-4 md:py-5 bg-slate-900 text-white rounded-[24px] font-black text-lg shadow-2xl active:scale-95 transition-all">确认并关闭详情</button></div>
        </div>
    </div>
    
    <div id="factoryModal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-900/70 backdrop-blur-lg">
        <div class="bg-white/95 backdrop-blur-xl w-full max-w-md rounded-[40px] p-10 shadow-2xl"><h3 class="text-2xl font-black mb-6 tracking-tighter text-center">新增代工厂档案</h3><div class="space-y-4"><input type="text" id="fName" placeholder="代工厂全称" class="w-full p-5 bg-slate-50/80 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-300 transition-all placeholder:text-slate-300" autocomplete="off"><input type="text" id="fAddr" placeholder="详细生产地址" class="w-full p-5 bg-slate-50/80 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-300 transition-all placeholder:text-slate-300" autocomplete="off"><button onclick="doSaveFactory()" class="w-full bg-gradient-to-r from-indigo-500 to-indigo-700 text-white py-5 rounded-2xl font-black shadow-xl shadow-indigo-200/50 active:scale-95 transition-all">保存工厂档案</button><button onclick="closeModal('factoryModal')" class="w-full text-slate-400 py-2 text-sm font-bold text-center w-full hover:text-slate-600 transition-colors">取消操作</button></div></div>
    </div>
    
    <div id="customerModal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-900/70 backdrop-blur-lg">
        <div class="bg-white/95 backdrop-blur-xl w-full max-w-md rounded-[40px] p-10 shadow-2xl"><h3 class="text-2xl font-black mb-6 tracking-tighter text-center">新增客户档案</h3><div class="space-y-4"><input type="text" id="cName" placeholder="客户姓名/公司名" class="w-full p-5 bg-slate-50/80 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-300 transition-all placeholder:text-slate-300" autocomplete="off"><input type="text" id="cAddr" placeholder="默认发货地址" class="w-full p-5 bg-slate-50/80 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-300 transition-all placeholder:text-slate-300" autocomplete="off"><input type="text" id="cPhone" placeholder="联系电话" class="w-full p-5 bg-slate-50/80 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-300 transition-all placeholder:text-slate-300" autocomplete="off"><button onclick="doSaveCustomer()" class="w-full bg-gradient-to-r from-indigo-500 to-indigo-700 text-white py-5 rounded-2xl font-black shadow-xl shadow-indigo-200/50 active:scale-95 transition-all">保存客户档案</button><button onclick="closeModal('customerModal')" class="w-full text-slate-400 py-2 text-sm font-bold text-center w-full hover:text-slate-600 transition-colors">取消操作</button></div></div>
    </div>


    <!-- 自定义确认弹窗 (解决原生 confirm 提示异常问题) -->
    <div id="confirmModal" class="hidden fixed inset-0 z-[500] flex items-center justify-center p-6 bg-slate-900/80 backdrop-blur-xl">
        <div class="bg-white/95 backdrop-blur-xl w-full max-w-sm rounded-[40px] p-10 shadow-2xl animate-in zoom-in-95 duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-rose-50 to-rose-100 rounded-2xl flex items-center justify-center text-rose-500 mx-auto mb-6"><i data-lucide="alert-triangle" class="w-8 h-8"></i></div>
            <h3 class="text-xl font-black text-slate-800 text-center mb-4">确认执行此操作？</h3>
            <p id="confirmMsg" class="text-sm text-slate-400 font-bold text-center mb-8 leading-relaxed"></p>
            <div class="space-y-3">
                <button id="confirmYes" class="w-full bg-gradient-to-r from-rose-500 to-rose-600 text-white py-5 rounded-2xl font-black shadow-xl shadow-rose-200/50 active:scale-95 transition-all">确认并执行</button>
                <button onclick="closeModal('confirmModal')" class="w-full bg-slate-100/80 text-slate-400 py-5 rounded-2xl font-black active:scale-95 transition-all hover:bg-slate-200/80">取消</button>
            </div>
        </div>
    </div>

    <script>
        // lucide CDN降级：若加载失败则定义空函数，避免JS报错阻断登录等核心功能
        if(typeof lucide === 'undefined') { window.lucide = { createIcons: () => {} }; }
        // 全局禁用数字输入框的鼠标滚轮调节功能，防止与页面滚动冲突
        document.addEventListener('wheel', function(e) { if (document.activeElement.type === 'number') document.activeElement.blur(); });

        let confirmCallback = null;
        function customConfirm(msg, cb) {
            getEl('confirmMsg').innerText = msg;
            confirmCallback = cb;
            openModal('confirmModal');
            getEl('confirmYes').onclick = () => {
                closeModal('confirmModal');
                if(confirmCallback) confirmCallback();
            };
            lucide.createIcons();
        }
        const api = axios.create({ baseURL: '/api' });
        api.interceptors.response.use(r => r, err => {
            if(err.code === 'ERR_NETWORK') toast('🚨 无法连接到服务器，请确保后端已启动并联网', 'bg-red-700');
            if(err.response?.status === 403 || err.response?.data?.message === 'Invalid Token') {
                toast('⚠️ 登录已过期，请重新登录', 'bg-amber-500');
                setTimeout(() => { localStorage.clear(); location.reload(); }, 1500);
            }
            return Promise.reject(err);
        });
        api.interceptors.request.use(config => { const token = localStorage.getItem('token'); if (token) config.headers.Authorization = `Bearer ${token}`; return config; });

                let currentUser = null; try { const stored = localStorage.getItem("user"); if(stored && stored !== "undefined") currentUser = JSON.parse(stored); } catch(e) { console.error("User parse error", e); localStorage.removeItem("user"); }
        let products = [], allCategories = [], allFactories = [], allCustomers = [];
        let qtyChart = null, valueChart = null, sampleChart = null;
        let displayCurrency = 'CNY', exchangeRate = 7.25;

        const getEl = (id) => document.getElementById(id);
        // HTML 转义：防止用户可控数据造成的存储型 XSS
        const esc = (v) => String(v ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
        const toast = (m, b) => { const t = getEl('toast'); t.innerText = m; t.className = `fixed bottom-10 left-1/2 -translate-x-1/2 z-[9999] px-8 py-5 rounded-[32px] shadow-2xl transition-all duration-500 font-black text-sm text-white ${b} text-center backdrop-blur-xl`; t.classList.remove('hidden'); setTimeout(() => t.classList.add('hidden'), 3500); };
        
        function openModal(id) { const el = getEl(id); if(el) { el.classList.remove('hidden'); const inner = el.querySelector('.modal-drawer'); if(inner) inner.classList.remove('hidden'); el.style.zIndex = '300'; document.body.style.overflow = 'hidden'; } }
        function closeModal(id) { const el = getEl(id); if(el) { el.classList.add('hidden'); document.body.style.overflow = ''; } }
        function toggleSidebar() { getEl('sidebar').classList.toggle('-translate-x-full'); getEl('sidebarOverlay').classList.toggle('hidden'); }
        function logout() { localStorage.clear(); location.reload(); }

        async function fetchExchangeRate() {
            const displays = document.querySelectorAll('.rate-display'); 
            displays.forEach(el => el.innerText = '正在尝试公网同步...');
            try { 
                const res = await api.get('/exchange-rate?force=true'); 
                exchangeRate = res.data.rate; 
                const updateTime = new Date(res.data.lastUpdate).toLocaleTimeString(); 
                displays.forEach(el => { 
                    el.innerHTML = `<i data-lucide="globe" class="w-2 h-2 mr-1 inline text-indigo-500"></i>最新公网汇率: 1 USD = ${exchangeRate} CNY <span class="opacity-40 font-normal ml-1">(${esc(updateTime)})</span>`; 
                }); 
                lucide.createIcons(); 
                renderInventory(); 
                renderTrans(); 
            } catch (e) { 
                displays.forEach(el => el.innerText = `公网连接超时，使用缓存汇率: 1 USD = ${exchangeRate} CNY`); 
            }
        }
        setInterval(fetchExchangeRate, 600000);

        async function fetchCategories() { 
            try { 
                const res = await api.get('/categories'); 
                allCategories = res.data; 
                const opts = allCategories.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join(''); 
                if(getEl('pCat')) getEl('pCat').innerHTML = opts; 
                if(getEl('qCat')) getEl('qCat').innerHTML = opts; 
                renderCategoryUI(); 
            } catch (e) { 
                console.error('fetchCategories:', e); 
            } 
            renderCategoryUI(); 
        }
        async function fetchFactories() { try { const res = await api.get('/factories'); allFactories = res.data; const opts = allFactories.map(f => `<option value="${f.id}">${esc(f.name)}</option>`).join(''); const h = '<option value="" disabled selected>选择指派代工厂...</option>' + opts; const pFactEl = getEl('pFact'); if(pFactEl) pFactEl.innerHTML = h; const qFactEl = getEl('qFact'); if(qFactEl) qFactEl.innerHTML = h; } catch (e) { console.error('fetchFactories:', e); } renderFactoryUI(); }
        async function fetchCustomers() { try { const res = await api.get('/customers'); allCustomers = res.data; const dlEl = getEl('customerDataList'); if(dlEl) dlEl.innerHTML = allCustomers.map(c => `<option value="${esc(c.name)}">`).join(''); } catch (e) { console.error('fetchCustomers:', e); } renderCustomerUI(); }

        async function login() {
            const u = getEl('username').value, p = getEl('password').value; if(!u || !p) return toast('⚠️ 请输入账号密码', 'bg-amber-500');
            getEl('btnLogin').disabled = true; getEl('btnLogin').innerText = '正在验证身份...';
            try { const res = await api.post('/login', { username: u, password: p }); localStorage.setItem('token', res.data.token); localStorage.setItem('user', JSON.stringify(res.data.user)); location.reload(); } 
            catch (e) { 
                const errorMsg = e.response?.data?.message || '用户名或密码错误';
                toast('❌ 登录失败：' + errorMsg, 'bg-red-600'); 
                getEl('btnLogin').disabled = false; getEl('btnLogin').innerText = '登 录'; 
            }
        }
        
        
        function showForgotPassword() {
            getEl('authTitle').innerText = '重置登录密钥';
            // 只保留用户名框，隐藏密码框
            getEl('loginFields').classList.remove('hidden');
            getEl('password').classList.add('hidden');
            getEl('regFields').classList.add('hidden');
            getEl('forgotFields').classList.remove('hidden');
            getEl('loginActions').classList.add('hidden');
            getEl('regActions').classList.add('hidden');
            getEl('forgotActions').classList.remove('hidden');
            getEl('forgotStep1').classList.remove('hidden');
            getEl('forgotStep2').classList.add('hidden');
            // 清空找回密码字段
            ['forgotPhone', 'forgotAnswer', 'forgotNewPass'].forEach(id => { const el = getEl(id); if(el) el.value = ''; });
        }
        async function verifyUserForForgot() {
            const u = getEl('username').value;
            if(!u) return toast('⚠️ 请先输入用户名', 'bg-amber-500');
            try {
                const res = await api.get('/forgot-password-verify', { params: { username: u } });
                getEl('displayQuestion').innerText = '密保问题: ' + res.data.question;
                getEl('forgotStep1').classList.add('hidden');
                getEl('forgotStep2').classList.remove('hidden');
            } catch(e) { toast('❌ 未找到该用户', 'bg-red-600'); }
        }
        async function resetPasswordNow() {
            const u = getEl('username').value, ph = getEl('forgotPhone').value, a = getEl('forgotAnswer').value, np = getEl('forgotNewPass').value;
            if(!ph || !a || !np) return toast('⚠️ 请填写完整验证信息', 'bg-amber-500');
            try {
                await api.post('/reset-password-now', { username: u, phone: ph, answer: a, newPassword: np });
                toast('✅ 密码重置成功，请登录', 'bg-emerald-600');
                toggleAuth(false);
            } catch(e) { toast('❌ 验证失败：信息不匹配', 'bg-red-600'); }
        }

        function toggleAuth(isReg) { 
            getEl('authTitle').innerText = isReg ? '注册新账号' : '欢迎回来'; 
            // 登录态：用户名+密码
            getEl('loginFields').classList.remove('hidden');
            getEl('password').classList.remove('hidden');
            // 注册额外字段
            getEl('regFields').classList.toggle('hidden', !isReg); 
            // 找回密码字段隐藏
            getEl('forgotFields').classList.add('hidden');
            // 按钮区切换
            getEl('loginActions').classList.toggle('hidden', isReg);
            getEl('regActions').classList.toggle('hidden', !isReg);
            getEl('forgotActions').classList.add('hidden');
        }
        async function register() { const u = getEl('username').value, p = getEl('password').value, ph = getEl('regPhone').value, q = getEl('regQuestion').value, a = getEl('regAnswer').value; if(!u || !p || !ph || !q || !a) return toast('⚠️ 请填写完整注册信息', 'bg-amber-500'); try { await api.post('/register', { username: u, password: p, phone: ph, question: q, answer: a }); toast('✅ 注册成功，欢迎加入', 'bg-emerald-500'); toggleAuth(false); } catch (e) { toast('❌ 注册失败：用户名可能已被占用', 'bg-red-600'); } }

        function initApp() {
            if (currentUser) {
                getEl('page-login').classList.add('hidden'); getEl('app-content').classList.remove('hidden'); getEl('sidebar').classList.remove('-translate-x-full');
                const bn = getEl('bottomNav'); if(bn) bn.classList.add('visible'); // 显示底部导航栏
                const roleMap = { 'admin': '系统超级管理员', 'manager': '部门主管专员', 'staff': '一线业务专员' }; const rd = getEl('roleDisplay'); if(rd) rd.innerText = roleMap[currentUser.role] || currentUser.role.toUpperCase();
                const sn = getEl('settingNewUsername'); if(sn) sn.value = currentUser.username;
                if (currentUser.role !== 'staff') document.querySelectorAll('.admin-only').forEach(el => el.classList.remove('hidden'));
                if (currentUser.role === 'admin') { const bs = getEl('backupSection'); if(bs) bs.classList.remove('hidden'); }
                lucide.createIcons(); showPage('dashboard'); fetchExchangeRate(); fetchCategories(); fetchFactories(); fetchCustomers(); fetchAlerts();
            } else { getEl('page-login').classList.remove('hidden'); getEl('app-content').classList.add('hidden'); const bn = getEl('bottomNav'); if(bn) bn.classList.remove('visible'); lucide.createIcons(); }
        }

        function showPage(id) {
            // 彻底清除所有可能的残留蒙版和弹窗
            const overlays = ['sidebarOverlay', 'prodModal', 'transModal', 'detailModal', 'factoryModal', 'customerModal', 'imgPreviewOverlay', 'changelogModal'];
            overlays.forEach(oid => {
                const el = getEl(oid);
                if(el) el.classList.add('hidden');
            });
            
            // 确保侧边栏在移动端导航后立即收起
            getEl('sidebar').classList.add('-translate-x-full');
            
            // 切换内容区域
            document.querySelectorAll('.page-content').forEach(p => p.classList.add('hidden'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            
            const targetPage = getEl(`page-${id}`);
            const targetNav = getEl(`nav-${id}`);
            
            if(targetPage) targetPage.classList.remove('hidden');
            if(targetNav) targetNav.classList.add('active');
            
            // 同步底部导航栏active状态
            document.querySelectorAll('.bottom-nav-item').forEach(item => {
                const page = item.dataset.page;
                item.classList.toggle('active', page === id || (page === 'factories' && (id === 'factories' || id === 'customers')));
            });
            
            // 重置滚动条位置和溢出属性
            document.body.style.overflow = '';
            const main = getEl('mainContainer');
            if(main) main.scrollTop = 0;
            
            // 触发对应页面的数据加载
            if (id === 'dashboard') { loadDash(); fetchAlerts(); } 
            if (id === 'inventory') renderInventory(); 
            if (id === 'transactions') renderTrans();
            if (id === 'factories') renderFactoryUI(); 
            if (id === 'customers') renderCustomerUI();
            if (id === 'settings' && currentUser.role !== 'staff') fetchUsers();
        }

        async function loadDash() {
            try {
                const [statsRes, invRes] = await Promise.all([api.get('/dashboard-stats'), api.get('/inventory')]);
                const { performance, leaderboard, productMix } = statsRes.data; products = invRes.data;
                getEl('statCards').innerHTML = [{t:'本月出库金额',v:formatMoney(performance.totalOut,'CNY'),c:'text-rose-600',i:'truck',bg:'from-rose-500 to-rose-600'},{t:'本月入库金额',v:formatMoney(performance.totalIn,'CNY'),c:'text-emerald-600',i:'download',bg:'from-emerald-500 to-emerald-600'},{t:'总业务流转',v:performance.transCount,c:'text-indigo-600',i:'activity',bg:'from-indigo-500 to-indigo-600'},{t:'当前款式总数',v:performance.activeSkus,c:'text-amber-600',i:'layers',bg:'from-amber-500 to-amber-600'}].map(c => `<div class="glass-card p-6 stat-card flex justify-between items-start" style="animation: fadeInUp 0.5s ease forwards"><div><p class="text-[10px] text-slate-400 font-black uppercase mb-2 tracking-widest">${c.t}</p><p class="text-3xl font-black ${c.c}">${c.v}</p></div><div class="bg-gradient-to-br ${c.bg} p-3 rounded-2xl shadow-lg shadow-${c.c.replace('text-','')}/20"><i data-lucide="${c.i}" class="w-5 h-5 text-white"></i></div></div>`).join('');
                if (currentUser.role !== 'staff' && leaderboard) getEl('perfList').innerHTML = leaderboard.map((u, i) => `<div class="p-5 bg-white border border-slate-50 rounded-[28px] flex items-center justify-between shadow-sm"><div class="flex items-center space-x-4"><div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-black text-indigo-600 shadow-inner">${i+1}</div><span class="font-black text-slate-700">${esc(u.username)}</span></div><span class="text-indigo-600 font-black">¥ ${u.totalAmount.toLocaleString()}</span></div>`).join('');
                const labels = productMix.map(p => p.name), qtyD = productMix.map(p => p.balance), valD = productMix.map(p => { const pr = products.find(prod => prod.name === p.name); return (p.balance * (pr?.unitPrice || 0)).toFixed(2); });
                const colors = ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#0ea5e9'];
                const isMobile = window.innerWidth <= 768;
                const doughnutOpts = (title) => ({
                    responsive: true, maintainAspectRatio: isMobile,
                    cutout: isMobile ? '55%' : '60%',
                    plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: isMobile ? 10 : 20, font: { weight: 'bold', size: isMobile ? 10 : 12 }, boxWidth: isMobile ? 8 : 12 } }, title: { display: false } },
                    layout: { padding: isMobile ? { bottom: 4 } : { bottom: 10 } }
                });
                if (qtyChart) qtyChart.destroy(); qtyChart = new Chart(getEl('productQtyChart'), { type: 'doughnut', data: { labels, datasets: [{ data: qtyD, backgroundColor: colors, borderWidth: 0, hoverOffset: isMobile ? 6 : 12 }] }, options: doughnutOpts('产品数量占比') });
                if (valueChart) valueChart.destroy(); valueChart = new Chart(getEl('productValueChart'), { type: 'doughnut', data: { labels, datasets: [{ data: valD, backgroundColor: colors, borderWidth: 0, hoverOffset: isMobile ? 6 : 12 }] }, options: doughnutOpts('资产价值分布') });
                const sampleProducts = products.filter(p => p.category && p.category.includes('样品'));
                if (sampleChart) sampleChart.destroy(); sampleChart = new Chart(getEl('sampleQtyChart'), { type: 'bar', data: { labels: sampleProducts.map(p => p.name), datasets: [{ data: sampleProducts.map(p => p.balance), backgroundColor: '#f59e0b', borderRadius: isMobile ? 8 : 12, barThickness: isMobile ? 18 : 24 }] }, options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, scales: { x: { grid: { display: false }, ticks: { font: { size: isMobile ? 10 : 12 } } }, y: { grid: { display: false }, ticks: { font: { weight: '800', size: isMobile ? 10 : 12 } } } } } });
                lucide.createIcons();
            } catch (e) { console.error('Dashboard load error:', e); }
        }

        function formatMoney(v, curr) { let val = parseFloat(v || 0); const orig = curr || 'CNY'; if (orig === 'USD' && displayCurrency === 'CNY') val *= exchangeRate; else if (orig === 'CNY' && displayCurrency === 'USD') val /= exchangeRate; return (displayCurrency === 'CNY' ? '¥' : '$') + val.toLocaleString(undefined, { minimumFractionDigits: 2 }); }
        function toggleDisplayCurrency() { displayCurrency = displayCurrency === 'CNY' ? 'USD' : 'CNY'; document.querySelectorAll('.currency-toggle-btn').forEach(b => b.innerText = `显示币种: ${displayCurrency}`); renderInventory(); renderTrans(); }

        async function renderInventory() {
            try {
                const res = await api.get('/inventory'); products = res.data; updateProductSelects();
                const term = getEl('invSearch').value.toLowerCase(); const sortField = getEl('invSortField').value;
                let filtered = products.filter(p => {
                    const matchesSearch = p.name.toLowerCase().includes(term) || p.sku.toLowerCase().includes(term);
                    return matchesSearch; // 移除权限过滤，全员可见
                });
                filtered.sort((a, b) => { let vA = a[sortField], vB = b[sortField]; if (sortField === 'value') { vA = a.balance * a.unitPrice; vB = b.balance * b.unitPrice; } return (typeof vA === 'string') ? vA.localeCompare(vB) : vB - vA; });
                
                // 计算汇总金额
                const totalVal = filtered.reduce((sum, p) => sum + (p.balance * p.unitPrice), 0);
                getEl('totalInvValue').innerText = formatMoney(totalVal, 'CNY');
                getEl('invTable').innerHTML = filtered.map(p => {
                    const fact = allFactories.find(f => f.id === p.factoryId); const isAdmin = currentUser.role !== 'staff';
