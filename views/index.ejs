                const cust = await getOrCreateCustomer(getEl('pCust').value, getEl('pCustAddr').value, getEl('pCustPhone').value);
                const fd = new FormData();
                const mapping = { name:'pName', sku:'pSku', category:'pCat', unitPrice:'pPrice', currency:'pCurr', packaging:'pPack', notes:'pNotes', factoryId:'pFact', spec:'pSpec', material:'pMat' };
                for(let k in mapping) { fd.append(k, getEl(mapping[k]).value); }
                fd.append('customerName', cust?.name || '通用'); 
                if(getEl('pImage').files[0]) {
                    const compressed = await compressImage(getEl('pImage').files[0]);
                    fd.append('image', compressed, 'compressed.jpg');
                }
                
                if(eid) await api.put(`/products/${eid}`, fd); else await api.post('/products', fd);
                closeModal('prodModal'); renderInventory(); toast('✅ 产品档案已成功保存', 'bg-emerald-600');
            } catch(e) { 
                console.error('Save Product Error:', e);
                toast('❌ 档案保存失败：可能是图片太大或网络超时', 'bg-red-600'); 
            } finally { 
                btn.disabled = false; 
                btn.innerText = '确认并保存档案';
                getEl('globalLoading').classList.add('hidden');
            }
        }

        
        function resetTransModal() {
            // 重置复选框
            const isNew = getEl('isNew');
            if(isNew) { isNew.checked = false; toggleQuickFields(); }
            
            // 清空下拉选择和基本输入
            ['tProd', 'tQty', 'tOrder', 'tLog', 'tNotes', 'qName', 'qSku', 'qPrice', 'qPack', 'qSpec', 'qMat', 'qCust', 'qCustAddr', 'qCustPhone'].forEach(id => {
                const el = getEl(id); if(el) el.value = '';
            });
            
            // 重置文件上传
            ['qImage', 'tImage'].forEach(id => {
                const el = getEl(id); if(el) el.value = '';
            });
            
            // 重置 Select 默认值
            ['tType', 'qCurr', 'qCat', 'qFact'].forEach(id => {
                const el = getEl(id); if(el && el.options[0]) el.selectedIndex = 0;
            });
        }

        async function doSaveTrans() {
            const btn = getEl('btnSaveTrans'); if(btn.disabled) return;
            const isN = getEl('isNew').checked;
            getEl('globalLoading').classList.remove('hidden');
            try {
                btn.disabled = true; 
                btn.innerText = '正在同步数据...';
                let pid = getEl('tProd').value;
                if(isN) {
                    btn.innerText = '正在建立新产品档案...';
                    const cust = await getOrCreateCustomer(getEl('qCust').value, getEl('qCustAddr').value, getEl('qCustPhone').value);
                    const fd = new FormData();
                    const qMap = { name:'qName', category:'qCat', unitPrice:'qPrice', currency:'qCurr', factoryId:'qFact', packaging:'qPack', sku:'qSku', spec:'qSpec', material:'qMat' };
                    for(let k in qMap) { fd.append(k, getEl(qMap[k]).value); }
                    fd.append('customerName', cust?.name || '通用'); 
                    if(getEl('qImage').files[0]) {
                        const compressed = await compressImage(getEl('qImage').files[0]);
                        fd.append('image', compressed, 'compressed.jpg');
                    }
                    const r = await api.post('/products', fd); 
                    pid = r.data.id;
                }
                if(!pid && !isN) {
                    getEl('globalLoading').classList.add('hidden');
                    return toast('⚠️ 请选择或录入产品', 'bg-amber-500');
                }
                
                btn.innerText = '正在保存流水记录...';
                const tfd = new FormData(); 
                tfd.append('productId', pid); 
                tfd.append('type', getEl('tType').value); 
                tfd.append('quantity', getEl('tQty').value); 
                tfd.append('orderNo', getEl('tOrder').value); 
                tfd.append('logisticsNo', getEl('tLog').value); 
                tfd.append('notes', getEl('tNotes').value);
                if(getEl('tImage').files[0]) {
                    const compressed = await compressImage(getEl('tImage').files[0]);
                    tfd.append('transImage', compressed, 'compressed.jpg');
                }
                await api.post('/transactions', tfd); 
                
                const finalInv = await api.get('/inventory');
                products = finalInv.data;
                resetTransModal(); 
                closeModal('transModal'); 
                renderTrans(); 
                renderInventory(); 
                toast('✅ 业务已成功入库', 'bg-emerald-600');
            } catch (e) { 
                console.error('Save Transaction Error:', e);
                toast('❌ 提交失败：请检查网络或必填项', 'bg-red-600'); 
            } finally { 
                btn.disabled = false; 
                btn.innerText = '立即提交业务记录';
                getEl('globalLoading').classList.add('hidden');
            }
        }

