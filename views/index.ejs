<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>库存专家 Pro - OEM 库存管理系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
        body { background-color: #f8fafc; font-family: 'Inter', -apple-system, sans-serif; -webkit-tap-highlight-color: transparent; }
        .nav-item { display: flex; align-items: center; padding: 0.8rem 1.25rem; color: #cbd5e1; transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; border-radius: 14px; margin: 0.2rem 0.75rem; }
        .nav-item:active { transform: scale(0.95); }
        .nav-item.active { background: #6366f1; color: white; box-shadow: 0 10px 20px -5px rgba(99,102,241,0.4); }
        .glass-card { background: white; border: 1px solid rgba(241,245,249,0.8); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02), 0 2px 4px -2px rgba(0,0,0,0.02); border-radius: 24px; transition: all 0.3s ease; }
        .clickable-row { cursor: pointer; }
        .clickable-row:active { transform: scale(0.98); background-color: #f1f5f9 !important; }
        .page-enter { animation: pageIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @keyframes pageIn { from { opacity: 0; transform: translateY(20px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @media (max-width: 768px) {
            .rate-display { font-size: 10px; padding: 4px 10px; border-radius: 8px; }
            .currency-toggle-btn { padding: 10px 16px; font-size: 12px; border-radius: 16px; }
            .modal-drawer { 
                position: fixed; bottom: 0; left: 0; right: 0; width: 100%; 
                border-radius: 48px 48px 0 0 !important; 
                max-height: 94vh !important; 
                padding-top: 12px;
                animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1); 
                display: flex; flex-direction: column;
                box-shadow: 0 -25px 50px -12px rgba(0,0,0,0.2);
                z-index: 300;
            }
            .modal-handle { width: 40px; height: 5px; background: #e2e8f0; border-radius: 10px; margin: 0 auto 15px; flex-shrink: 0; }
            @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
            .modal-scroll { padding-bottom: 80px; padding-left: 20px; padding-right: 20px; }
            .glass-card { border-radius: 32px; padding: 1.25rem !important; }
            .text-4xl { font-size: 1.875rem !important; line-height: 2.25rem !important; }
            .p-10 { padding: 1.5rem !important; }
        }
        .modal-scroll { overflow-y: auto !important; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
        .detail-scroll-fix { overflow-y: auto !important; -webkit-overflow-scrolling: touch; }
        .detail-scroll-fix::-webkit-scrollbar { display: block; width: 6px; }
        .detail-scroll-fix::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
        
        /* 图片悬停放大特效 - 增强版 */
        .hover-zoom-trigger { 
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease; 
            cursor: zoom-in; 
            position: relative; 
            z-index: 10;
            will-change: transform;
            transform-origin: left center; /* 从左向右展开，避开侧边栏 */
        }
        .hover-zoom-trigger:hover { 
            transform: scale(3.8) translateX(15px); 
            z-index: 999 !important; 
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
            border-radius: 12px;
        }
        /* 确保表格容器不拦截溢出内容 */
        .table-container-fix { overflow: visible !important; }
        
        /* 移除数字输入框的滚轮调节和箭头，防止滚动冲突 */
        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        input[type=number] { -moz-appearance: textfield; }
        .error-bubble { color: #e11d48; font-size: 10px; font-weight: 800; margin-top: 4px; animation: shake 0.4s ease; }
        @keyframes shake { 0%,100% {transform:translateX(0)} 25% {transform:translateX(-4px)} 75% {transform:translateX(4px)} }
    </style>
</head>

<body class="flex h-screen overflow-hidden text-slate-800 select-none">
    <div id="toast" class="hidden fixed bottom-10 left-1/2 -translate-x-1/2 z-[300] px-6 py-4 rounded-3xl shadow-2xl transition-all duration-500 font-black text-sm flex items-center text-white min-w-[280px] justify-center text-center"></div>
    <!-- 全局加载遮罩 -->
    <div id="globalLoading" class="hidden fixed inset-0 z-[600] bg-slate-900/40 backdrop-blur-md flex flex-col items-center justify-center">
        <div class="w-20 h-20 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-white font-black text-lg tracking-widest animate-pulse">正在同步云端数据库...</p>
        <p class="text-white/60 text-xs mt-2">首次上传图片可能较慢，请勿关闭页面</p>
    </div>
    <div id="imgPreviewOverlay" onclick="this.classList.add('hidden')" class="hidden fixed inset-0 z-[400] bg-black/95 backdrop-blur-2xl flex items-center justify-center p-4">
        <img id="imgPreviewContent" src="" class="max-w-full max-h-full rounded-3xl shadow-2xl border border-white/10 animate-in zoom-in-95 duration-300">
    </div>

    <aside id="sidebar" class="fixed inset-y-0 left-0 z-[100] w-72 bg-slate-900 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-500 cubic-bezier(0.16, 1, 0.3, 1) flex flex-col shadow-2xl">
        <div class="p-8 border-b border-slate-800/50 flex items-center space-x-4">
            <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/20"><i data-lucide="package" class="text-white w-6 h-6"></i></div>
            <div><h1 class="text-white font-black tracking-tighter text-xl text-center">库存专家</h1><p id="roleDisplay" class="text-[10px] text-slate-500 font-black uppercase tracking-widest text-center"></p></div>
        </div>
        <div class="mt-8 flex-1 space-y-1 overflow-y-auto px-2">
            <div onclick="showPage('dashboard')" id="nav-dashboard" class="nav-item active"><i data-lucide="layout-grid" class="w-5 h-5 mr-4"></i> 仪表盘看板</div>
            <div onclick="showPage('inventory')" id="nav-inventory" class="nav-item"><i data-lucide="box" class="w-5 h-5 mr-4"></i> 库存台账</div>
            <div onclick="showPage('transactions')" id="nav-transactions" class="nav-item"><i data-lucide="refresh-ccw" class="w-5 h-5 mr-4"></i> 收发明细</div>
            <div onclick="showPage('factories')" id="nav-factories" class="nav-item"><i data-lucide="factory" class="w-5 h-5 mr-4"></i> 工厂档案</div>
            <div onclick="showPage('customers')" id="nav-customers" class="nav-item"><i data-lucide="users" class="w-5 h-5 mr-4"></i> 客户档案</div>
            <div onclick="showPage('settings')" id="nav-settings" class="nav-item"><i data-lucide="settings" class="w-5 h-5 mr-4"></i> 系统设置</div>
        </div>
        <div class="p-6 border-t border-slate-800/50"><button onclick="logout()" class="w-full flex items-center justify-center space-x-3 py-4 bg-slate-800/50 text-slate-400 hover:text-red-400 rounded-2xl transition-all font-bold text-sm active:scale-95"><i data-lucide="log-out" class="w-4 h-4"></i><span>退出登录</span></button></div>
    </aside>

    <div id="sidebarOverlay" onclick="toggleSidebar()" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[90]"></div>

    <div class="flex-1 flex flex-col min-w-0 bg-slate-50 relative">
        <header class="md:hidden bg-white/80 backdrop-blur-md border-b border-slate-100 p-5 flex justify-between items-center z-[80] sticky top-0">
            <div class="flex items-center space-x-3"><div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-100"><i data-lucide="package" class="text-white w-5 h-5"></i></div><span class="font-black text-slate-900 tracking-tighter">库存专家 Pro</span></div>
            <button onclick="toggleSidebar()" class="p-3 bg-slate-50 rounded-xl text-slate-600 active:scale-90 transition-transform"><i data-lucide="menu" class="w-6 h-6"></i></button>
        </header>

        <main id="mainContainer" class="flex-1 overflow-y-auto p-4 lg:p-10 space-y-6">
            <!-- 登录/注册 -->
            <div id="page-login" class="min-h-[80vh] flex items-center justify-center p-4">
                <div class="w-full max-w-sm bg-white p-10 rounded-[40px] shadow-2xl border border-indigo-50/50">
                    <div class="text-center mb-10"><div class="w-20 h-20 bg-indigo-600 rounded-[32px] flex items-center justify-center shadow-2xl shadow-indigo-200 mx-auto mb-6"><i data-lucide="shield-check" class="text-white w-10 h-10"></i></div><h2 id="authTitle" class="text-3xl font-black text-slate-900 tracking-tighter text-center">欢迎回来</h2></div>
                    <div class="space-y-4" id="loginForm">
                        <input type="text" id="username" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] focus:ring-2 focus:ring-indigo-500 outline-none transition-all font-bold text-center" placeholder="用户名" autocomplete="off">
                        <input type="password" id="password" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] focus:ring-2 focus:ring-indigo-500 outline-none transition-all font-bold text-center" placeholder="登录密码" autocomplete="off">
                        <div id="loginGroup" class="pt-2"><button id="btnLogin" onclick="login()" class="w-full bg-indigo-600 text-white py-5 rounded-[22px] font-black text-lg shadow-xl shadow-indigo-100 active:scale-95 transition-transform">登 录</button>
                            <div class="flex justify-between mt-6 px-2"><button onclick="toggleAuth(true)" class="text-slate-400 font-bold text-xs hover:text-indigo-600">注册新账号</button><button onclick="showForgotPassword()" class="text-indigo-500 font-bold text-xs underline underline-offset-4">忘记密码?</button></div>
                        </div>
                        <div id="regGroup" class="hidden pt-2 space-y-4">
                            <input type="text" id="regPhone" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] focus:ring-2 focus:ring-indigo-500 outline-none font-bold" placeholder="手机号 (仅用于找回密码)" autocomplete="off">
                            <select id="regQuestion" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] font-bold text-slate-500 appearance-none text-center"><option value="" disabled selected>设置密保问题</option><option value="出生地">您的出生地是哪里？</option><option value="母亲姓名">您母亲的姓名是？</option><option value="第一只宠物">第一只宠物的名字？</option></select>
                            <input type="text" id="regAnswer" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] font-bold text-center" placeholder="密保答案" autocomplete="off">
                            <button id="btnReg" onclick="register()" class="w-full bg-emerald-600 text-white py-5 rounded-[22px] font-black text-lg shadow-xl active:scale-95 transition-transform">完成注册并返回登录</button>
                        </div>
                        <div id="forgotGroup" class="hidden pt-2 space-y-4">
                            <div id="forgotStep1" class="space-y-4 text-center"><p class="text-xs text-slate-400 font-bold px-4 leading-relaxed">系统将根据用户名调取密保问题</p><button onclick="verifyUserForForgot()" class="w-full bg-indigo-600 text-white py-5 rounded-[22px] font-black active:scale-95 transition-transform">获取我的密保问题</button></div>
                            <div id="forgotStep2" class="hidden space-y-4 text-center"><div class="bg-indigo-50 p-5 rounded-[22px] text-indigo-700 text-xs font-black border border-indigo-100/50" id="displayQuestion"></div><input type="text" id="forgotPhone" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] text-center" placeholder="预留手机号" autocomplete="off"><input type="text" id="forgotAnswer" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] text-center" placeholder="密保答案" autocomplete="off"><input type="password" id="forgotNewPass" class="w-full px-6 py-5 bg-slate-50 border-0 rounded-[22px] text-center" placeholder="新密码 (6位以上)" autocomplete="off"><button onclick="resetPasswordNow()" class="w-full bg-indigo-600 text-white py-5 rounded-[22px] font-black shadow-xl active:scale-95 transition-transform">重置并登录系统</button></div>
                            <button onclick="toggleAuth(false)" class="w-full text-slate-400 font-bold text-xs mt-4">放弃重置</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 系统主内容 -->
            <div id="app-content" class="hidden space-y-8 pb-20">
                <div id="page-dashboard" class="page-content hidden space-y-8 page-enter">
                    <div class="flex items-center justify-between"><h2 class="text-4xl font-black text-slate-900 tracking-tighter text-center">业务大盘</h2><span id="perfTag" class="px-4 py-1.5 bg-white border border-slate-100 text-slate-400 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm"></span></div>
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5" id="statCards"></div>
                    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
                        <div class="glass-card p-8"><h3 class="text-xl font-black mb-8 text-slate-700 text-center">产品数量占比</h3><div class="h-[300px] md:h-[400px]"><canvas id="productQtyChart"></canvas></div></div>
                        <div class="glass-card p-8"><h3 class="text-xl font-black mb-8 text-slate-700 text-center">资产价值分布</h3><div class="h-[300px] md:h-[400px]"><canvas id="productValueChart"></canvas></div></div>
                    </div>
                    <div class="glass-card p-8"><h3 class="text-xl font-black mb-8 flex items-center text-slate-700 justify-center"><i data-lucide="beaker" class="mr-3 text-amber-500"></i>样品库实时存量 (包)</h3><div class="h-[350px] md:h-[500px]"><canvas id="sampleQtyChart"></canvas></div></div>
                    <div class="admin-only hidden glass-card p-8"><h3 class="text-xl font-black mb-8 text-slate-700 flex items-center justify-center"><i data-lucide="award" class="mr-3 text-orange-400"></i>员工贡献榜</h3><div id="perfList" class="grid grid-cols-1 md:grid-cols-3 gap-6"></div></div>
                </div>

                <!-- 库存台账 -->
                <div id="page-inventory" class="page-content hidden space-y-6 page-enter">
                    <div class="flex justify-between items-center">
                        <h2 class="text-4xl font-black text-slate-900 tracking-tighter text-center">库存台账</h2>
                        <div class="flex flex-col items-end space-y-1">
                            <div class="flex items-center space-x-3">
                                <button onclick="toggleDisplayCurrency()" class="currency-toggle-btn px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-black text-indigo-600 shadow-sm active:scale-95 transition-all">显示币种: CNY</button>
                                <button onclick="openAddProdModal()" class="bg-indigo-600 text-white w-14 h-14 rounded-2xl shadow-2xl shadow-indigo-200 flex items-center justify-center active:scale-90 transition-transform"><i data-lucide="plus" class="w-8 h-8"></i></button>
                            </div>
                            <span onclick="fetchExchangeRate()" class="rate-display cursor-pointer hover:text-indigo-600 transition-colors text-[9px] font-black text-slate-400 bg-slate-100 px-2 py-0.5 rounded-md tracking-widest text-center" title="点击手动刷新汇率">正在同步汇率...</span>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="md:col-span-2 flex bg-white px-4 py-1 rounded-[22px] border border-slate-100 shadow-sm focus-within:ring-4 focus-within:ring-indigo-500/10 transition-all"><i data-lucide="search" class="m-4 text-slate-300"></i><input type="text" id="invSearch" oninput="renderInventory()" placeholder="搜索产品名称、货号..." class="flex-1 bg-transparent outline-none font-bold text-lg" autocomplete="off"></div>
                        <div class="glass-card bg-indigo-600 p-4 flex items-center justify-between text-white shadow-xl shadow-indigo-100">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center"><i data-lucide="calculator" class="w-5 h-5 text-white"></i></div>
                                <div>
                                    <p class="text-[9px] font-black uppercase opacity-60 tracking-widest">当前库存总估值</p>
                                    <p id="totalInvValue" class="text-xl font-black tracking-tighter">¥ 0.00</p>
                                </div>
                            </div>
                        </div>
                        <div class="md:col-span-3 flex items-center space-x-3 bg-white px-6 py-4 rounded-[22px] shadow-sm border border-slate-100 self-end md:self-start"><span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Sort By:</span><select id="invSortField" onchange="renderInventory()" class="bg-transparent outline-none font-black text-sm text-indigo-600"><option value="id">录入时间</option><option value="name">产品名称</option><option value="customerName">客户维度</option><option value="balance">库存量</option><option value="value">资产价值</option></select></div>
                    </div>
                    <div class="hidden md:block glass-card table-container-fix overflow-x-auto border border-slate-100">
                        <table class="w-full text-left border-collapse table-fixed min-w-[1000px]">
                            <thead class="bg-slate-50/50 border-b border-slate-100">
                                <tr>
                                    <th class="w-[16%] p-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">产品名称</th>
                                    <th class="w-[16%] p-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">参数 (品类/尺寸/材质)</th>
                                    <th class="w-[16%] p-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">维度 (客户/工厂)</th>
                                    <th class="w-[18%] p-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">计价/库存</th>
                                    <th class="w-[10%] p-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">最后经办</th>
                                    <th class="w-[24%] p-8 text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">资产总额 (实时)</th>
                                </tr>
                            </thead>
                            <tbody id="invTable" class="divide-y divide-slate-50"></tbody>
                        </table>
                    </div>
                    <div id="invMobile" class="md:hidden space-y-5"></div>
                </div>

                <!-- 收发明细 -->
                <div id="page-transactions" class="page-content hidden space-y-6 page-enter">
                    <div class="flex justify-between items-center">
                        <h2 class="text-4xl font-black text-slate-900 tracking-tighter text-center">收发明细</h2>
                        <div class="flex flex-col items-end space-y-1">
                            <div class="flex items-center space-x-3">
                                <button onclick="toggleDisplayCurrency()" class="currency-toggle-btn px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-black text-indigo-600 shadow-sm active:scale-95 transition-all">显示币种: CNY</button>
                                <button onclick="openModal('transModal')" class="bg-indigo-600 text-white px-8 py-4 rounded-[22px] shadow-2xl shadow-indigo-200 font-black flex items-center active:scale-95 transition-transform"><i data-lucide="plus-circle" class="w-5 h-5 mr-3"></i>立即记账</button>
                            </div>
                            <span onclick="fetchExchangeRate()" class="rate-display cursor-pointer hover:text-indigo-600 transition-colors text-[9px] font-black text-slate-400 bg-slate-100 px-2 py-0.5 rounded-md tracking-widest text-center" title="点击手动刷新汇率">正在同步汇率...</span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3 bg-white px-6 py-4 rounded-[22px] shadow-sm border border-slate-100 self-start"><span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Order:</span><select id="transSortField" onchange="renderTrans()" class="bg-transparent outline-none font-black text-sm text-indigo-600"><option value="date">日期倒序</option><option value="quantity">数量大小</option></select></div>
                    <div id="transList" class="space-y-6"></div>
                </div>

                <!-- 辅助档案 -->
                <div id="page-factories" class="page-content hidden space-y-6 page-enter"><div class="flex justify-between items-center"><h2 class="text-4xl font-black text-slate-900 tracking-tighter">工厂档案库</h2><button onclick="openModal('factoryModal')" class="admin-only hidden bg-indigo-600 text-white w-14 h-14 rounded-2xl shadow-xl flex items-center justify-center active:scale-90 transition-transform"><i data-lucide="plus"></i></button></div><div id="factoryListContent" class="grid grid-cols-1 md:grid-cols-3 gap-6"></div></div>
                <div id="page-customers" class="page-content hidden space-y-6 page-enter"><div class="flex justify-between items-center"><h2 class="text-4xl font-black text-slate-900 tracking-tighter">合作客户库</h2><button onclick="openModal('customerModal')" class="admin-only hidden bg-indigo-600 text-white w-14 h-14 rounded-2xl shadow-xl flex items-center justify-center active:scale-90 transition-transform"><i data-lucide="plus"></i></button></div><div id="customerListContent" class="grid grid-cols-1 md:grid-cols-3 gap-6"></div></div>

                <div id="page-settings" class="page-content hidden space-y-8 page-enter">
                    <h2 class="text-4xl font-black text-slate-900 tracking-tighter">系统中心</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                        <!-- 个人资料 -->
                        <div class="glass-card p-6 md:p-10 space-y-6 md:space-y-8">
                            <div class="flex items-center space-x-4 border-b border-slate-100 pb-4">
                                <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600"><i data-lucide="user"></i></div>
                                <h3 class="text-xl font-black text-slate-700">账号个人信息</h3>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2 px-1">当前显示姓名</label>
                                    <input type="text" id="settingNewUsername" class="w-full bg-slate-50 p-4 md:p-5 rounded-[22px] font-black border-0 outline-none focus:ring-4 focus:ring-indigo-500/10 transition-all text-lg text-slate-700" autocomplete="off">
                                </div>
