                    getEl('tQty')?.addEventListener('input', validateStockQty);
                } else {
                    getEl('stockHint')?.classList.add('hidden');
                    getEl('stockWarning')?.classList.add('hidden');
                }
                
                if(typeof lucide !== 'undefined') lucide.createIcons();
                openModal('transModal');
            } catch (err) { console.error(err); }
        }

        async function doSaveTrans() {
            const btn = getEl('btnSaveTrans'); if(btn.disabled) return;
            const type = getEl('tType').value;
            const isN = getEl('isNew').checked && type === 'in';
            getEl('globalLoading').classList.remove('hidden');
            try {
                btn.disabled = true; 
                btn.innerText = '正在同步数据...';
                
                // 必填项校验
                const qtyVal = getEl('tQty').value.trim();
                if(!qtyVal || isNaN(Number(qtyVal)) || Number(qtyVal) <= 0) {
                    getEl('globalLoading').classList.add('hidden');
                    btn.disabled = false; btn.innerText = '立即提交业务记录';
                    return toast('⚠️ 请输入有效的数量（正整数）', 'bg-amber-500');
                }
                if(isN && !getEl('qName').value.trim()) {
                    getEl('globalLoading').classList.add('hidden');
                    btn.disabled = false; btn.innerText = '立即提交业务记录';
                    return toast('⚠️ 新产品名称不能为空', 'bg-amber-500');
                }
                
                let pid = getEl('tProd').value;
                if(isN) {
                    btn.innerText = '正在建立新产品档案...';
                    const cust = await getOrCreateCustomer(getEl('qCust').value, getEl('qCustAddr').value, getEl('qCustPhone').value);
                    const fd = new FormData();
                    const qMap = { name:'qName', category:'qCat', unitPrice:'qPrice', currency:'qCurr', factoryId:'qFact', packaging:'qPack', sku:'qSku', spec:'qSpec', material:'qMat' };
                    for(let k in qMap) { fd.append(k, getEl(qMap[k]).value); }
                    fd.append('customerName', cust?.name || ''); 
                    if(getEl('qImage').files[0]) {
                        const compressed = await compressImage(getEl('qImage').files[0]);
                        fd.append('image', compressed, 'compressed.jpg');
                    }
                    const r = await api.post('/products', fd); 
                    pid = r.data.id;
                }
                if(!pid && !isN) {
                    getEl('globalLoading').classList.add('hidden');
                    return toast('⚠️ 请选择产品', 'bg-amber-500');
                }
                
                // 出库前端预校验：数量 > 库存则拦截
                if(type === 'out' && !isN && pid) {
                    const prod = products.find(p => String(p.id) === String(pid));
                    if(prod && typeof prod.balance === 'number' && Number(qtyVal) > prod.balance) {
                        getEl('globalLoading').classList.add('hidden');
                        btn.disabled = false; btn.innerText = '立即提交业务记录';
                        return toast(`⚠️ 库存不足！当前库存 ${prod.balance} 包，无法出库 ${qtyVal} 包`, 'bg-rose-600');
                    }
                }
                
                if(type === 'out' && getEl('tCustomer').value) {
                    await getOrCreateCustomer(getEl('tCustomer').value);
                }
                
                btn.innerText = '正在保存流水记录...';
                const tfd = new FormData(); 
                tfd.append('productId', pid); 
                tfd.append('type', type); 
                tfd.append('quantity', getEl('tQty').value); 
                tfd.append('orderNo', getEl('tOrder').value); 
                tfd.append('logisticsNo', getEl('tLog').value); 
                tfd.append('customerName', (type === 'out' && getEl('tCustomer').value) ? getEl('tCustomer').value : '');
                tfd.append('receiver', (type === 'out' && getEl('tReceiver')?.value) ? getEl('tReceiver').value : '');
                tfd.append('batchNo', getEl('tBatchNo')?.value || '');
                tfd.append('notes', getEl('tNotes').value);
                if(getEl('tImage').files[0]) {
                    const compressed = await compressImage(getEl('tImage').files[0]);
                    tfd.append('transImage', compressed, 'compressed.jpg');
                }
                await api.post('/transactions', tfd); 
                
                const finalInv = await api.get('/inventory');
                products = finalInv.data;
                resetTransModal(); closeModal('transModal'); renderTrans(); renderInventory(); 
                toast('✅ 业务已成功同步', 'bg-emerald-600');
            } catch (e) { 
                console.error(e);
                const errMsg = e.response?.data?.message || e.message || '请检查网络或必填项';
                toast('❌ 提交失败：' + errMsg, 'bg-red-600'); 
            } finally { 
                btn.disabled = false; btn.innerText = '立即提交业务记录';
                getEl('globalLoading').classList.add('hidden');
            }
        }

