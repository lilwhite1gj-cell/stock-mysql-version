        async function doSaveFactory() { try { const payload = { name: getEl('fName').value, address: getEl('fAddr').value }; if(!payload.name) return toast('⚠️ 请填写工厂名称', 'bg-amber-500'); const res = await api.post('/factories', payload); allFactories.push(res.data); toast('✅ 工厂档案已建立', 'bg-emerald-500'); closeModal('factoryModal'); renderFactoryUI(); fetchFactories(); } catch(e) { toast('❌ 保存失败', 'bg-red-500'); } }
        async function doSaveCustomer() { try { const payload = { name: getEl('cName').value, address: getEl('cAddr').value, phone: getEl('cPhone').value }; if(!payload.name) return toast('⚠️ 请填写客户名称', 'bg-amber-500'); const res = await api.post('/customers', payload); allCustomers.push(res.data); toast('✅ 客户档案已成功建立', 'bg-emerald-500'); closeModal('customerModal'); renderCustomerUI(); fetchCustomers(); } catch(e) { toast('❌ 保存失败', 'bg-red-500'); } }

        function renderFactoryUI() { const isAdmin = currentUser.role !== 'staff'; getEl('factoryListContent').innerHTML = allFactories.map(f => `<div class="glass-card p-8 shadow-lg relative group transition-all" style="border-top: 6px solid ${f.color}; border-radius: 24px;">${isAdmin ? `<button onclick="doDeleteFactory('${f.id}')" class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 p-2.5 text-rose-300 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : ''}<h4 class="text-2xl font-black text-slate-800 mb-2 tracking-tight">${esc(f.name)}</h4><p class="text-xs text-slate-400 font-bold tracking-widest">${esc(f.address || '未录入生产地址')}</p></div>`).join(''); lucide.createIcons(); }
        function renderCustomerUI() { const isAdmin = currentUser.role !== 'staff'; const filtered = allCustomers.filter(c => isAdmin || c.createdBy === currentUser.id); getEl('customerListContent').innerHTML = filtered.map(c => `<div class="glass-card p-8 flex flex-col justify-between min-h-[160px] shadow-sm relative group transition-all">${isAdmin ? `<button onclick="doDeleteCustomer('${c.id}')" class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 p-2.5 text-rose-300 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all active:scale-90"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : ''}<h4 class="text-2xl font-black text-slate-800 tracking-tight">${esc(c.name)}</h4><div class="space-y-1"><p class="text-xs text-slate-400 font-bold">${esc(c.address || '暂无详细发货地址')}</p><p class="text-xs text-indigo-500 font-black tracking-widest">${esc(c.phone || '-')}</p></div></div>`).join(''); lucide.createIcons(); }
        function renderCategoryUI() { getEl('categoryList').innerHTML = allCategories.map(c => { const safeName = btoa(unescape(encodeURIComponent(c))); return `<div class="px-5 py-2.5 bg-indigo-50 text-indigo-600 rounded-2xl text-[11px] font-black flex items-center border border-indigo-100/50 shadow-sm transition-all hover:scale-105"><span>${esc(c)}</span><button onclick="handleDeleteCategory('${safeName}')" class="ml-3 p-1 opacity-40 hover:opacity-100 hover:text-rose-500 transition-all font-bold text-lg">×</button></div>`; }).join(''); }
        async function handleDeleteCategory(encodedName) { const n = decodeURIComponent(escape(atob(encodedName))); if(!confirm(`彻底销毁品类 [${n}] 吗？`)) return; try { await api.delete(`/categories/${encodeURIComponent(n)}`); toast('✅ 已销毁', 'bg-emerald-600'); fetchCategories(); } catch(e) { toast('❌ 失败', 'bg-red-600'); } }
        async function addCategory() { const n = getEl('newCatName').value; if(!n) return; await api.post('/categories', { name: n }); getEl('newCatName').value=''; fetchCategories(); toast('✅ 已更新', 'bg-emerald-500'); }
        // --- 库存预警 ---
        async function fetchAlerts() {
            if (currentUser.role !== 'admin') return;
            try {
                const res = await api.get('/inventory/alerts?threshold=10');
                const alerts = res.data;
                const section = getEl('alertSection');
                const list = getEl('alertList');
                if (!section || !list) return;
                if (alerts.length === 0) { section.classList.add('hidden'); return; }
                section.classList.remove('hidden');
                list.innerHTML = alerts.map(p => `
                    <div class="flex items-center justify-between p-4 bg-rose-50 rounded-2xl border border-rose-100">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-xl bg-rose-100 flex items-center justify-center text-rose-600"><i data-lucide="alert-triangle" class="w-5 h-5"></i></div>
                            <div>
                                <p class="font-black text-slate-800">${esc(p.name)}</p>
                                <p class="text-[10px] text-slate-400 font-bold">${esc(p.sku || '无货号')} · ${esc(p.category || '未分类')}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-2xl font-black text-rose-600">${p.balance}</p>
                            <p class="text-[9px] text-rose-400 font-black">剩余库存</p>
                        </div>
                    </div>
                `).join('');
                lucide.createIcons();
            } catch(e) { console.error('Alerts error:', e); }
        }

        // --- CSV 导出 ---
        async function exportInventoryCSV() {
            try {
                const token = localStorage.getItem('token');
                const res = await fetch('/api/export/inventory', { headers: { 'Authorization': 'Bearer ' + token } });
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = 'inventory_' + new Date().toISOString().slice(0,10) + '.csv';
                document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
                toast('✅ 库存台账已导出', 'bg-emerald-600');
            } catch(e) { toast('❌ 导出失败', 'bg-red-600'); }
        }
        async function exportTransCSV() {
            try {
                const token = localStorage.getItem('token');
                const res = await fetch('/api/export/transactions', { headers: { 'Authorization': 'Bearer ' + token } });
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = 'transactions_' + new Date().toISOString().slice(0,10) + '.csv';
                document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
                toast('✅ 收发明细已导出', 'bg-emerald-600');
            } catch(e) { toast('❌ 导出失败', 'bg-red-600'); }
        }

        // --- 日期筛选清除 ---
        function clearTransDateFilter() {
            const s = getEl('transStartDate'), e = getEl('transEndDate');
            if(s) s.value = ''; if(e) e.value = '';
            renderTrans();
        }

        async function exportBackup() {
            try {
                toast('⏳ 正在导出备份...', 'bg-blue-600');
                const res = await api.get('/backup/export', { responseType: 'blob' });
                const blob = new Blob([JSON.stringify(res.data, null, 2)], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `inventory_backup_${new Date().toISOString().slice(0, 10)}.json`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                toast('✅ 备份文件已下载', 'bg-emerald-600');
            } catch(e) {
                toast('❌ 导出失败：' + (e.response?.data?.message || e.message), 'bg-red-600');
            }
        }

        async function importBackup(event) {
            const file = event.target.files[0];
            if (!file) return;
            customConfirm('⚠️ 导入将覆盖当前所有数据！此操作不可撤销。确认继续？', async () => {
                try {
                    toast('⏳ 正在导入恢复...', 'bg-blue-600');
                    const text = await file.text();
                    const data = JSON.parse(text);
                    const res = await api.post('/backup/import', data);
                    toast(`✅ 恢复成功！用户:${res.data.stats.users} 产品:${res.data.stats.products} 流水:${res.data.stats.transactions}`, 'bg-emerald-600', 5000);
                    setTimeout(() => location.reload(), 2000);
                } catch(e) {
                    toast('❌ 导入失败：' + (e.response?.data?.message || '文件格式无效'), 'bg-red-600');
                }
            });
            event.target.value = '';
        }

        async function updateProfile(isU) { const payload = isU ? { newUsername: getEl('settingNewUsername').value } : { oldPassword: getEl('oldPass').value, newPassword: getEl('newPass').value }; try { const res = await api.post('/update-profile', payload); toast('✅ 已同步', 'bg-emerald-600'); if(isU) { localStorage.setItem('user', JSON.stringify(res.data.user)); setTimeout(() => location.reload(), 1000); } else { getEl('oldPass').value=''; getEl('newPass').value=''; } } catch(e) { toast('❌ 失败', 'bg-red-500'); } }

        function openAddProdModal() { getEl('editProdId').value=''; ['pName','pSku','pPrice','pPack','pNotes','pCust','pCustAddr','pCustPhone','pMat','pSpec'].forEach(id => { const el = getEl(id); if(el) el.value=''; }); getEl('pCurr').value='CNY'; getEl('prodModalTitle').innerText = '档案录入'; openModal('prodModal'); updateDynamicHints('p'); }
        function openEditModal(id) { const p = products.find(x => x.id === id); getEl('editProdId').value = p.id; ['pName','pSku','pPrice','pPack','pNotes','pCust','pMat','pSpec'].forEach(f => { getEl(f).value = p[f.replace('p', '').toLowerCase()] || ''; }); getEl('pName').value = p.name; getEl('pSku').value = p.sku; getEl('pPrice').value = p.unitPrice; getEl('pPack').value = p.packaging; getEl('pCust').value = p.customerName; const cust = allCustomers.find(c => c.name === p.customerName); getEl('pCustAddr').value = cust ? cust.address : ''; getEl('pCustPhone').value = cust ? cust.phone : ''; getEl('pCat').value = p.category || ''; getEl('pFact').value = p.factoryId || ''; getEl('pCurr').value = p.currency || 'CNY'; getEl('prodModalTitle').innerText = '档案修改'; updateDynamicHints('p'); openModal('prodModal'); }
        function toggleQuickFields() { const isN = getEl('isNew').checked; getEl('oldPBox').classList.toggle('hidden', isN); getEl('newPBox').classList.toggle('hidden', !isN); if(isN) updateDynamicHints('q'); }
        function previewImg(u) { getEl('imgPreviewContent').src = u; getEl('imgPreviewOverlay').classList.remove('hidden'); }
        function updateProductSelects() { const el = getEl('tProd'); if(el) el.innerHTML = '<option value="" disabled selected>🔍 选择产品...</option>' + products.map(p => `<option value="${p.id}">${esc(p.name)} / ${esc(p.sku)}</option>`).join(''); }

        // --- 版本信息 ---
        let appVersion = '1.1.51';
        async function fetchVersion() {
            try {
                const res = await api.get('/version');
                appVersion = res.data.version || '1.1.0';
                const badge = getEl('versionBadge');
                if (badge) badge.textContent = 'v' + appVersion;
                // 提取最新版本日期
                const match = (res.data.changelog || '').match(/##\s*\[.*?\]\s*-\s*(\d{4}-\d{2}-\d{2})/);
                const dateEl = getEl('versionDate');
                if (dateEl) dateEl.textContent = match ? match[1] : '';
            } catch(e) { /* 静默失败 */ }
        }
        function parseChangelog(md) {
            const versions = [];
            const blocks = md.split(/^## /m).filter(b => b.trim());
            for (const block of blocks) {
                const headerMatch = block.match(/^\[(.*?)\]\s*-\s*(\d{4}-\d{2}-\d{2})/);
                if (!headerMatch) continue;
                const version = headerMatch[1], date = headerMatch[2];
                const sections = {};
                let currentSection = '';
                for (const line of block.split('\n')) {
                    const secMatch = line.match(/^###\s+(.+)/);
                    if (secMatch) { currentSection = secMatch[1]; sections[currentSection] = []; continue; }
                    if (currentSection && line.trim().startsWith('- ')) {
                        sections[currentSection].push(line.trim().replace(/^- /, ''));
                    }
                }
                versions.push({ version, date, sections });
            }
            return versions;
        }
        function showChangelog() {
            api.get('/version').then(res => {
                const md = res.data.changelog || '';
                const versions = parseChangelog(md);
                const container = getEl('changelogContent');
                if (!versions.length) { container.innerHTML = '<p class="text-slate-400 text-center py-10">暂无更新记录</p>'; }
                else {
                    container.innerHTML = versions.map((v, i) => {
                        const isNewest = i === 0;
                        const sectionLabels = { '新增': 'bg-emerald-50 text-emerald-700 border-emerald-200', '修复': 'bg-rose-50 text-rose-700 border-rose-200', '变更': 'bg-amber-50 text-amber-700 border-amber-200', '核心功能': 'bg-indigo-50 text-indigo-700 border-indigo-200' };
                        const sectionsHtml = Object.entries(v.sections).map(([name, items]) => {
                            const labelClass = sectionLabels[name] || 'bg-slate-50 text-slate-600 border-slate-200';
                            return `<div class="space-y-2"><span class="inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest border ${labelClass}">${esc(name)}</span><ul class="space-y-1.5 pl-1">${items.map(item => `<li class="text-xs text-slate-500 leading-relaxed">${esc(item.replace(/^[^\s]+\s/, ''))}</li>`).join('')}</ul></div>`;
                        }).join('');
                        return `<div class="${isNewest ? 'bg-indigo-50/50 border border-indigo-100 rounded-[24px] p-6' : 'border-l-4 border-slate-100 pl-6 py-4'}"><div class="flex items-center space-x-3 mb-3"><span class="font-black text-slate-800 text-base">v${esc(v.version)}</span><span class="text-[10px] text-slate-400 font-bold">${esc(v.date)}</span>${isNewest ? '<span class="px-2 py-0.5 bg-indigo-500 text-white rounded-lg text-[10px] font-black">最新</span>' : ''}</div><div class="space-y-4">${sectionsHtml}</div></div>`;
                    }).join('');
                }
                getEl('changelogModal').classList.remove('hidden');
                lucide.createIcons();
            }).catch(() => toast('❌ 无法加载更新日志', 'bg-red-500'));
        }

        initApp();
        fetchVersion();
    </script>

    <!-- 移动端底部导航栏 -->
    <div class="bottom-nav" id="bottomNav">
        <div class="bottom-nav-item active" data-page="dashboard" onclick="showPage('dashboard')">
            <i data-lucide="layout-grid"></i><span>看板</span>
        </div>
        <div class="bottom-nav-item" data-page="inventory" onclick="showPage('inventory')">
            <i data-lucide="box"></i><span>台账</span>
        </div>
        <div class="bottom-nav-item" data-page="transactions" onclick="showPage('transactions')">
            <i data-lucide="refresh-ccw"></i><span>明细</span>
        </div>
        <div class="bottom-nav-item" data-page="factories" onclick="showPage('factories')">
            <i data-lucide="archive"></i><span>档案</span>
        </div>
        <div class="bottom-nav-item" data-page="settings" onclick="showPage('settings')">
            <i data-lucide="settings"></i><span>设置</span>
        </div>
    </div>
</body>
</html>