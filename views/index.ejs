        async function renderTrans() {
            try {
                // 构建带日期筛选的API请求
                const params = new URLSearchParams();
                const filterType = getEl('transFilterType').value;
                const startDate = getEl('transStartDate')?.value;
                const endDate = getEl('transEndDate')?.value;
                if (filterType !== 'all') params.set('type', filterType);
                if (startDate) params.set('startDate', startDate);
                if (endDate) params.set('endDate', endDate);
                
                const res = await api.get('/transactions?' + params.toString()); 
                let data = res.data;
                const sortType = getEl('transSortField').value;
                const layoutMode = getEl('transLayoutMode').value;
                
                // 1. 排序逻辑（类型和日期已由API过滤）
                const sortFn = (a, b) => {
                    if (sortType === 'dateDesc') return new Date(b.date) - new Date(a.date);
                    if (sortType === 'dateAsc') return new Date(a.date) - new Date(b.date);
                    if (sortType === 'qtyDesc') return b.quantity - a.quantity;
                    if (sortType === 'valDesc') {
                        const pA = products.find(x => x.id === a.productId), pB = products.find(x => x.id === b.productId);
                        return (b.quantity * (pB?.unitPrice || 0)) - (a.quantity * (pA?.unitPrice || 0));
                    }
                    return 0;
                };
                data.sort(sortFn);

                // 辅助：生成卡片 HTML 的内部函数
                const createCardHtml = (t) => {
                    const p = products.find(x => x.id === t.productId), isIn = t.type === 'in';
                    const isAdmin = currentUser.role === 'admin' || currentUser.role === 'manager';
                    const customerTag = t.customerName ? `<span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded-md text-[9px] font-black border border-indigo-100/50 mr-2">${isIn?'来源':'去向'}: ${esc(t.customerName)}</span>` : '';
                    const receiverTag = (!isIn && t.receiver) ? `<span class="px-2 py-0.5 bg-amber-50 text-amber-600 rounded-md text-[9px] font-black border border-amber-100/50 mr-2"><i data-lucide="user-check" class="w-2 h-2 inline mr-1"></i>领用: ${esc(t.receiver)}</span>` : '';
                    const batchTag = t.batchNo ? `<span class="px-2 py-0.5 bg-slate-50 text-slate-500 rounded-md text-[9px] font-black border border-slate-200/50 mr-2">批次: ${esc(t.batchNo)}</span>` : '';
                    const operatorTag = `<span class="px-2 py-0.5 bg-slate-100 text-slate-500 rounded-md text-[9px] font-black border border-slate-200"><i data-lucide="user" class="w-2 h-2 inline mr-1"></i>经办: ${esc(t.username)}</span>`;
                    const imgPreview = t.image ? `<img src="${esc(t.image)}" class="w-16 h-16 md:w-20 md:h-20 rounded-2xl object-cover shadow-lg border-2 border-white cursor-zoom-in flex-shrink-0" onclick="event.stopPropagation(); previewImg(this.src)">` : `<div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-slate-100 flex items-center justify-center text-slate-300 border-2 border-dashed border-slate-200 flex-shrink-0"><i data-lucide="image" class="w-6 h-6"></i></div>`;
                    const delBtn = isAdmin ? `<button onclick="event.stopPropagation(); doDeleteTrans('${t.id}')" class="p-2.5 bg-rose-50 text-rose-400 rounded-xl active:scale-90 transition-all hover:bg-rose-100"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : '';
                    
                    return `
                    <div class="glass-card p-4 md:p-6 border-l-[6px] md:border-l-[10px] ${isIn ? 'border-emerald-500' : 'border-rose-500'} flex flex-row items-center gap-4 animate-in slide-in-from-bottom-2 shadow-sm hover:shadow-md transition-all clickable-row" onclick="showTransDetail('${t.id}')">
                        ${imgPreview}
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class="text-[8px] font-black text-slate-300 tracking-widest uppercase">${new Date(t.date).toLocaleDateString()}</span>
                                ${customerTag}${receiverTag}${batchTag}${operatorTag}
                            </div>
                            <h4 class="text-sm md:text-lg font-black truncate text-slate-800 tracking-tighter">${p ? p.name : '已删'}</h4>
                            <div class="flex items-center justify-between mt-2">
                                <div class="text-xs font-black text-slate-900">${formatMoney(t.quantity * (p?.unitPrice || 0), p?.currency)}</div>
                                <div class="text-[10px] font-black ${isIn ? 'text-emerald-600' : 'text-rose-600'}">${isIn ? '+' : '-'}${t.quantity} Bags</div>
                            </div>
                        </div>
                        ${delBtn}
                    </div>`;
                };

                // 3. 布局逻辑
                if (layoutMode === 'double') {
                    getEl('transList').classList.add('hidden');
                    getEl('transDoubleContainer').classList.remove('hidden');
                    
                    const inData = data.filter(x => x.type === 'in');
                    const outData = data.filter(x => x.type === 'out');
                    
                    getEl('inCountTag').innerText = inData.length;
                    getEl('outCountTag').innerText = outData.length;
                    
                    getEl('transInList').innerHTML = inData.length ? inData.map(createCardHtml).join('') : '<p class="text-center text-[10px] text-slate-300 py-10 font-bold uppercase tracking-widest">暂无入库数据</p>';
                    getEl('transOutList').innerHTML = outData.length ? outData.map(createCardHtml).join('') : '<p class="text-center text-[10px] text-slate-300 py-10 font-bold uppercase tracking-widest">暂无出库数据</p>';
                } else {
                    getEl('transList').classList.remove('hidden');
                    getEl('transDoubleContainer').classList.add('hidden');
                    getEl('transList').innerHTML = data.length ? data.map(createCardHtml).join('') : '<div class="glass-card p-20 text-center space-y-4"><div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto text-slate-200"><i data-lucide="archive" class="w-8 h-8"></i></div><p class="text-slate-400 font-black tracking-widest text-sm uppercase">所选范围内无业务记录</p></div>';
                }

                lucide.createIcons();
            } catch (e) { console.error('Render Trans Error:', e); }
        }

        function updateDynamicHints(prefix) {
            const catEl = getEl(prefix + 'Cat');
            const cat = catEl ? catEl.value : '';
            const isSample = cat.includes('样品');
            
            const optionalSuffixes = ['Sku', 'Cust', 'Fact', 'Price', 'Curr', 'Pack', 'Notes', 'CustAddr', 'CustPhone'];
            
            optionalSuffixes.forEach(s => {
                const el = getEl(prefix + s);
                if(!el) return;
                
                let baseHint = '';
                if (el.tagName === 'SELECT') {
                    if (el.options && el.options.length > 0) {
                        baseHint = el.options[0].text.replace(' (选填)', '');
                    }
                } else {
                    baseHint = (el.getAttribute('placeholder') || '').replace(' (选填)', '');
                }
                
                if(!baseHint) return;

                if(isSample) {
                    if(el.tagName === 'SELECT') {
                        if(el.options && el.options.length > 0) el.options[0].text = baseHint + ' (选填)';
                    } else {
                        el.setAttribute('placeholder', baseHint + ' (选填)');
                    }
                    el.classList.add('bg-slate-50', 'text-slate-400');
                    el.classList.remove('bg-white', 'bg-slate-100');
                } else {
                    if(el.tagName === 'SELECT') {
                        if(el.options && el.options.length > 0) el.options[0].text = baseHint;
                    } else {
                        el.setAttribute('placeholder', baseHint);
                    }
                    el.classList.remove('bg-slate-50', 'text-slate-400');
                    el.classList.add(prefix === 'p' ? 'bg-slate-100' : 'bg-white');
                }
            });
        }

        async function getOrCreateCustomer(name, addr, phone) {
            if(!name || name === '通用') return { name: '通用' };
            const existing = allCustomers.find(c => c.name === name);
            if(existing) return existing;
            try {
                const res = await api.post('/customers', { name, address: addr, phone });
                await fetchCustomers();
                return res.data;
            } catch(e) { return { name }; }
        }

        
        async function compressImage(file, maxWidth = 1024, quality = 0.7) {
            if(!file.type.startsWith('image/')) {
                throw new Error('请选择图片文件（支持 JPG/PNG/WebP 格式）');
            }
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = e => {
                    const img = new Image();
                    img.src = e.target.result;
                    img.onload = () => {
                        try {
                            const canvas = document.createElement('canvas');
                            let width = img.width, height = img.height;
                            if (width > maxWidth) { height = Math.round((height * maxWidth) / width); width = maxWidth; }
                            canvas.width = width; canvas.height = height;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, width, height);
                            canvas.toBlob(blob => {
                                if(blob) resolve(blob);
                                else reject(new Error('图片压缩失败，请重试'));
                            }, 'image/jpeg', quality);
                        } catch(err) { reject(new Error('图片处理失败：' + err.message)); }
                    };
                    img.onerror = () => reject(new Error('图片加载失败，请确认文件是否损坏'));
                };
                reader.onerror = () => reject(new Error('文件读取失败'));
            });
        }

        async function doSaveProduct() {
            const btn = getEl('btnSaveProd'); if(btn.disabled) return;
            const eid = getEl('editProdId').value;
            getEl('globalLoading').classList.remove('hidden');
            try {
                btn.disabled = true; 
                btn.innerText = '正在上传数据...';
                const cust = await getOrCreateCustomer(getEl('pCust').value, getEl('pCustAddr').value, getEl('pCustPhone').value);
                const fd = new FormData();
                const mapping = { name:'pName', sku:'pSku', category:'pCat', unitPrice:'pPrice', currency:'pCurr', packaging:'pPack', notes:'pNotes', factoryId:'pFact', spec:'pSpec', material:'pMat' };
                for(let k in mapping) { fd.append(k, getEl(mapping[k]).value); }
                fd.append('customerName', cust?.name || '通用'); 
                if(getEl('pImage').files[0]) {
                    const compressed = await compressImage(getEl('pImage').files[0]);
                    fd.append('image', compressed, 'compressed.jpg');
                }
                
                if(eid) await api.put(`/products/${eid}`, fd); else await api.post('/products', fd);
                closeModal('prodModal'); renderInventory(); toast('✅ 产品档案已成功保存', 'bg-emerald-600');
            } catch(e) { 
                console.error('Save Product Error:', e);
                const errMsg = e.response?.data?.message || e.message || '图片太大或网络超时';
                toast('❌ 档案保存失败：' + errMsg, 'bg-red-600'); 
            } finally { 
                btn.disabled = false; 
                btn.innerText = '确认并保存档案';
                getEl('globalLoading').classList.add('hidden');
            }
        }

        
        // ===== 出库库存校验：前端预检 + 实时提示 =====
        let _selectedProductBalance = -1; // -1 = 未选择产品
        
        function updateStockHint() {
            const pid = getEl('tProd')?.value;
            const hintEl = getEl('stockHint');
            const hintVal = getEl('stockHintValue');
            const warnEl = getEl('stockWarning');
            if (!pid || !hintEl) { if(hintEl) hintEl.classList.add('hidden'); if(warnEl) warnEl.classList.add('hidden'); _selectedProductBalance = -1; return; }
            const prod = products.find(p => String(p.id) === String(pid));
            if (prod && typeof prod.balance === 'number') {
                _selectedProductBalance = prod.balance;
                hintEl.classList.remove('hidden');
                hintVal.textContent = `${prod.balance} 包`;
                hintVal.className = `text-xl font-black ${prod.balance > 0 ? 'text-amber-600' : 'text-rose-600'}`;
                if(warnEl) warnEl.classList.add('hidden');
            } else {
                _selectedProductBalance = -1;
                hintEl.classList.add('hidden');
            }
            validateStockQty();
        }
        
        function validateStockQty() {
            const warnEl = getEl('stockWarning');
            const warnText = getEl('stockWarningText');
            if (!warnEl || _selectedProductBalance < 0) return;
            const qty = parseInt(getEl('tQty')?.value);
            if (isNaN(qty) || qty <= 0) { warnEl.classList.add('hidden'); return; }
            if (qty > _selectedProductBalance) {
                warnEl.classList.remove('hidden');
                warnText.textContent = `出库数量 ${qty} 超过可用库存 ${_selectedProductBalance}，将无法提交`;
            } else {
                warnEl.classList.add('hidden');
            }
        }

        function resetTransModal() {
            try {
                // 重置库存提示
                _selectedProductBalance = -1;
                getEl('stockHint')?.classList.add('hidden');
                getEl('stockWarning')?.classList.add('hidden');
                getEl('tProd')?.removeEventListener('change', updateStockHint);
                getEl('tQty')?.removeEventListener('input', validateStockQty);
                
                // 重置复选框
                const isNew = getEl('isNew');
                if(isNew) { isNew.checked = false; toggleQuickFields(); }
                
                // 清空基本输入
                ['tProd', 'tQty', 'tOrder', 'tLog', 'tNotes', 'qName', 'qSku', 'qPrice', 'qPack', 'qSpec', 'qMat', 'qCust', 'qCustAddr', 'qCustPhone', 'tCustomer', 'tReceiver', 'tBatchNo'].forEach(id => {
                    const el = getEl(id); if(el) el.value = '';
                });
                
                // 重置文件上传
                ['qImage', 'tImage'].forEach(id => {
                    const el = getEl(id); if(el) el.value = '';
                });
                
                // 重置 Select 默认值
                ['tType', 'qCurr', 'qCat', 'qFact'].forEach(id => {
                    const el = getEl(id); if(el && el.options[0]) el.selectedIndex = 0;
                });
            } catch (e) { console.error('Reset Modal Error:', e); }
        }

