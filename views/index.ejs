        function renderCustomerUI() { 
            const isAdmin = currentUser.role === 'admin' || currentUser.role === 'manager';
            // 权限隔离优化：管理员见全部；员工见自己创建的 或 与自己产品相关的
            const filtered = allCustomers.filter(c => {
                if (isAdmin) return true;
                const isCreator = c.createdBy === currentUser.id;
                const hasRelatedProduct = products.some(p => p.customerName === c.name && p.createdBy === currentUser.id);
                return isCreator || hasRelatedProduct;
            });
            
            getEl('customerListContent').innerHTML = filtered.map(c => `
                <div class="glass-card p-8 flex flex-col justify-between min-h-[160px] shadow-sm relative group">
                    ${isAdmin ? `<button onclick="doDeleteCustomer('${c.id}')" class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 p-2 text-rose-300 hover:text-rose-600 transition-all active:scale-90"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : ''}
                    <h4 class="text-2xl font-black text-slate-800 tracking-tighter">${c.name}</h4>
                    <div class="space-y-1">
                        <p class="text-xs text-slate-400 font-bold">${c.address || '暂无详细发货地址'}</p>
                        <p class="text-xs text-indigo-500 font-black tracking-widest">${c.phone || '-'}</p>
                    </div>
                </div>`).join(''); 
            lucide.createIcons();
        }
        function renderCategoryUI() { 
            getEl('categoryList').innerHTML = allCategories.map(c => {
                // 使用 base64 或 16进制编码来安全传递中文字符串作为参数
                const safeName = btoa(unescape(encodeURIComponent(c)));
                return `
                <div class="px-5 py-2.5 bg-indigo-50 text-indigo-600 rounded-2xl text-[11px] font-black flex items-center border border-indigo-100/50 shadow-sm transition-all hover:scale-105">
                    <span>${c}</span>
                    <button onclick="handleDeleteCategory('${safeName}')" class="ml-3 p-1 opacity-40 hover:opacity-100 hover:text-rose-500 transition-all font-bold text-lg">×</button>
                </div>`;
            }).join(''); 
        }

        async function handleDeleteCategory(encodedName) {
            const n = decodeURIComponent(escape(atob(encodedName)));
            if(!confirm(`彻底销毁品类 [${n}] 吗？此操作将从全局目录移除该选项。`)) return;
            try {
                await api.delete(`/categories/${encodeURIComponent(n)}`);
                toast('✅ 品类已成功销毁', 'bg-emerald-600');
                fetchCategories();
            } catch(e) {
                toast('❌ 销毁失败：权限不足或网络异常', 'bg-red-600');
            }
        }

        
        async function addCategory() { const n = getEl('newCatName').value; if(!n) return; await api.post('/categories', { name: n }); getEl('newCatName').value=''; fetchCategories(); toast('✅ 品类目录已更新', 'bg-emerald-500'); }
        async function updateProfile(isU) { 
            const payload = isU ? { newUsername: getEl('settingNewUsername').value } : { oldPassword: getEl('oldPass').value, newPassword: getEl('newPass').value };
            try { const res = await api.post('/update-profile', payload); toast('✅ 资料已实时同步', 'bg-emerald-600'); if(isU) { localStorage.setItem('user', JSON.stringify(res.data.user)); setTimeout(() => location.reload(), 1000); } else { getEl('oldPass').value=''; getEl('newPass').value=''; } } 
            catch(e) { toast('❌ 操作失败', 'bg-red-500'); }
        }

        function openAddProdModal() { getEl('editProdId').value=''; ['pName','pSku','pPrice','pPack','pNotes','pCust','pCustAddr','pCustPhone','pMat','pSpec'].forEach(id => { const el = getEl(id); if(el) el.value=''; }); getEl('pCurr').value='CNY'; getEl('prodModalTitle').innerText = '档案录入'; openModal('prodModal'); updateDynamicHints('p'); }
        function openEditModal(id) { 
            const p = products.find(x => x.id === id); 
            getEl('editProdId').value = p.id; 
            
            // 显式映射字段，解决原有代码回填失败的问题
            getEl('pName').value = p.name || '';
            getEl('pSku').value = p.sku || '';
            getEl('pPrice').value = p.unitPrice || '';
            getEl('pPack').value = p.packaging || '';
            getEl('pNotes').value = p.notes || '';
            getEl('pCust').value = p.customerName || '';
            getEl('pMat').value = p.material || '';
            getEl('pSpec').value = p.spec || '';
            
            // 尝试从本地客户列表中匹配并回填联系信息
            const cust = allCustomers.find(c => c.name === p.customerName);
            getEl('pCustAddr').value = cust ? (cust.address || '') : '';
            getEl('pCustPhone').value = cust ? (cust.phone || '') : '';

            getEl('pCat').value = p.category || ''; 
            getEl('pFact').value = p.factoryId || ''; 
            getEl('pCurr').value = p.currency || 'CNY'; 
            
            getEl('prodModalTitle').innerText = '档案修改'; 
            updateDynamicHints('p'); 
            openModal('prodModal'); 
        }
        function toggleQuickFields() { const isN = getEl('isNew').checked; getEl('oldPBox').classList.toggle('hidden', isN); getEl('newPBox').classList.toggle('hidden', !isN); if(isN) updateDynamicHints('q'); }
        function previewImg(u) { getEl('imgPreviewContent').src = u; getEl('imgPreviewOverlay').classList.remove('hidden'); }
        function updateProductSelects() { const el = getEl('tProd'); if(el) el.innerHTML = '<option value="" disabled selected>🔍 搜索并选择产品档案...</option>' + products.map(p => `<option value="${p.id}">${p.name}  /  ${p.sku}</option>`) .join(''); }

        initApp();
    </script>
</body>
</html>
